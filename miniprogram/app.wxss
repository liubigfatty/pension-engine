/* app.wxss - 全局设计系统 v2.0 */

/* ============================================
   设计变量（CSS Custom Properties）
   ============================================ */

page {
  /* 颜色系统 */
  --color-primary: #07c160;
  --color-primary-dark: #06ae56;
  --color-primary-light: #e6f7ff;
  
  --color-success: #07c160;
  --color-warning: #ffc107;
  --color-danger: #e74c3c;
  --color-info: #1577d6;
  
  --color-text-primary: #1a1a1a;
  --color-text-secondary: #666;
  --color-text-hint: #999;
  --color-text-white: #fff;
  
  --color-bg-page: #f5f5f5;
  --color-bg-card: #fff;
  --color-bg-input: #f5f5f5;
  --color-bg-disabled: #f5f5f5;
  
  --color-border: #e0e0e0;
  --color-border-focus: #07c160;
  
  /* 字体系统 */
  --font-size-xs: 22rpx;    /* 辅助文字 */
  --font-size-sm: 26rpx;    /* 次要文字 */
  --font-size-base: 30rpx;  /* 正文 */
  --font-size-md: 34rpx;    /* 小标题 */
  --font-size-lg: 38rpx;    /* 标题 */
  --font-size-xl: 44rpx;   /* 大标题 */
  --font-size-xxl: 56rpx;  /* 首页品牌名 */
  
  --font-weight-normal: 400;
  --font-weight-medium: 500;
  --font-weight-bold: 700;
  
  --line-height-tight: 1.3;
  --line-height-normal: 1.6;
  --line-height-loose: 1.8;
  
  /* 间距系统（基于8rpx） */
  --space-xs: 8rpx;      /* 8rpx */
  --space-sm: 16rpx;     /* 16rpx */
  --space-md: 24rpx;     /* 24rpx */
  --space-lg: 32rpx;     /* 32rpx */
  --space-xl: 48rpx;     /* 48rpx */
  --space-xxl: 64rpx;    /* 64rpx */
  
  /* 圆角系统 */
  --radius-sm: 8rpx;
  --radius-md: 12rpx;
  --radius-lg: 16rpx;
  --radius-xl: 24rpx;
  --radius-round: 50rpx;  /* 全圆角 */
  
  /* 阴影系统 */
  --shadow-sm: 0 2rpx 8rpx rgba(0,0,0,0.05);
  --shadow-md: 0 4rpx 16rpx rgba(0,0,0,0.08);
  --shadow-lg: 0 8rpx 32rpx rgba(0,0,0,0.12);
  --shadow-primary: 0 8rpx 32rpx rgba(7,193,96,0.35);
  
  /* 过渡动画 */
  --transition-fast: 0.2s ease;
  --transition-normal: 0.3s ease;
  
  /* 基础样式 */
  background-color: var(--color-bg-page);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
  line-height: var(--line-height-normal);
}

/* ============================================
   全局容器
   ============================================ */

.container {
  padding: var(--space-lg);
  min-height: 100vh;
  box-sizing: border-box;
}

.step-container {
  padding: var(--space-xl) var(--space-lg);
  min-height: 100vh;
  box-sizing: border-box;
  padding-bottom: 200rpx;
}

/* ============================================
   标题系统
   ============================================ */

.page-title {
  font-size: var(--font-size-xl);
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
  margin-bottom: var(--space-xs);
  display: block;
}

.page-desc {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  margin-bottom: var(--space-xl);
  display: block;
  line-height: var(--line-height-tight);
}

.section-title {
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
  margin-bottom: var(--space-sm);
  display: block;
}

.section-desc {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  margin-bottom: var(--space-md);
  display: block;
}

/* ============================================
   表单组件
   ============================================ */

.form-group {
  margin-bottom: var(--space-lg);
}

.form-label {
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-primary);
  margin-bottom: var(--space-sm);
  display: block;
}

.form-hint {
  font-size: var(--font-size-xs);
  color: var(--color-text-hint);
  margin-top: var(--space-xs);
  display: block;
  line-height: var(--line-height-tight);
}

.form-required::before {
  content: '*';
  color: var(--color-danger);
  margin-right: var(--space-xs);
}

/* 选择器（统一风格：灰底、全圆角） */
.picker-box {
  background: var(--color-bg-input);
  border: 2rpx solid transparent;
  border-radius: var(--radius-round);
  padding: var(--space-md) var(--space-lg);
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
  position: relative;
  transition: all var(--transition-fast);
}

.picker-box:active {
  background: #eee;
}

.picker-box.placeholder {
  color: var(--color-text-hint);
}

.picker-arrow {
  position: absolute;
  right: var(--space-lg);
  top: 50%;
  transform: translateY(-50%);
  color: var(--color-text-hint);
  font-size: var(--font-size-sm);
}

/* 输入框（统一风格：灰底、全圆角） */
.input-box {
  background: var(--color-bg-input);
  border: 2rpx solid transparent;
  border-radius: var(--radius-round);
  padding: var(--space-md) var(--space-lg);
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
  width: 100%;
  box-sizing: border-box;
  transition: all var(--transition-fast);
}

.input-box:focus {
  background: var(--color-bg-card);
  border-color: var(--color-border-focus);
}

.input-box::placeholder {
  color: var(--color-text-hint);
}

/* 单选按钮组 */
.radio-group {
  display: flex;
  gap: var(--space-sm);
  flex-wrap: wrap;
}

.radio-item {
  flex: 1;
  min-width: 200rpx;
  background: var(--color-bg-input);
  border: 2rpx solid transparent;
  border-radius: var(--radius-round);
  padding: var(--space-md) var(--space-lg);
  text-align: center;
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
  transition: all var(--transition-fast);
}

.radio-item:active {
  background: #eee;
}

.radio-item.active {
  background: var(--color-primary);
  color: var(--color-text-white);
  border-color: var(--color-primary);
}

/* 日期选择器 */
.date-picker {
  background: var(--color-bg-input);
  border: 2rpx solid transparent;
  border-radius: var(--radius-round);
  padding: var(--space-md) var(--space-lg);
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
  transition: all var(--transition-fast);
}

/* ============================================
   按钮系统（统一风格：全圆角）
   ============================================ */

/* 主按钮 */
.btn-primary {
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
  color: var(--color-text-white);
  border: none;
  border-radius: var(--radius-round);
  padding: var(--space-md) 0;
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-medium);
  width: 100%;
  text-align: center;
  transition: all var(--transition-normal);
  position: relative;
  overflow: hidden;
}

.btn-primary:active {
  opacity: 0.85;
  transform: scale(0.98);
}

.btn-primary.disabled,
.btn-primary[disabled] {
  background: #ccc;
  color: #fff;
}

/* 次按钮 */
.btn-secondary {
  background: var(--color-bg-card);
  color: var(--color-primary);
  border: 2rpx solid var(--color-primary);
  border-radius: var(--radius-round);
  padding: var(--space-md) 0;
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-medium);
  width: 100%;
  text-align: center;
  transition: all var(--transition-fast);
}

.btn-secondary:active {
  background: var(--color-primary-light);
}

/* 文字按钮 */
.btn-text {
  background: transparent;
  color: var(--color-primary);
  border: none;
  padding: var(--space-sm) 0;
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-medium);
  text-align: center;
}

.btn-text:active {
  opacity: 0.7;
}

/* 底部按钮固定区域 */
.btn-bottom {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: var(--space-lg);
  background: var(--color-bg-card);
  box-shadow: 0 -4rpx 12rpx rgba(0,0,0,0.08);
  padding-bottom: calc(var(--space-lg) + env(safe-area-inset-bottom));
}

.btn-area {
  display: flex;
  gap: var(--space-sm);
}

.btn-area .btn-secondary {
  width: 25%;
}

.btn-area .btn-primary {
  flex: 1;
}

/* ============================================
   卡片系统
   ============================================ */

.card {
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: var(--space-lg);
  margin-bottom: var(--space-md);
  box-shadow: var(--shadow-sm);
}

.card-title {
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
  margin-bottom: var(--space-sm);
  display: block;
}

.card-desc {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  line-height: var(--line-height-tight);
}

/* ============================================
   提示框系统
   ============================================ */

.tip-box {
  display: flex;
  align-items: flex-start;
  padding: var(--space-md);
  background: var(--color-primary-light);
  border-radius: var(--radius-md);
  border-left: 8rpx solid var(--color-warning);
  margin-bottom: var(--space-lg);
}

.tip-icon {
  font-size: var(--font-size-sm);
  margin-right: var(--space-sm);
}

.tip-text {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  line-height: var(--line-height-tight);
  flex: 1;
}

/* ============================================
   进度条系统
   ============================================ */

.progress-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-lg) 0;
  margin-bottom: var(--space-xl);
}

.progress-step {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  position: relative;
}

.step-dot {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: var(--color-bg-input);
  border: 4rpx solid var(--color-border);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-size-xs);
  color: var(--color-text-hint);
  margin-bottom: var(--space-xs);
  z-index: 1;
}

.progress-step.active .step-dot {
  background: var(--color-primary);
  border-color: var(--color-primary);
  color: var(--color-text-white);
}

.progress-step.done .step-dot {
  background: var(--color-primary);
  border-color: var(--color-primary);
  color: var(--color-text-white);
}

.step-line {
  position: absolute;
  top: 24rpx;
  left: 50%;
  width: 100%;
  height: 4rpx;
  background: var(--color-border);
  z-index: 0;
}

.progress-step:last-child .step-line {
  display: none;
}

.progress-step.done .step-line {
  background: var(--color-primary);
}

.step-label {
  font-size: var(--font-size-xs);
  color: var(--color-text-hint);
}

.progress-step.active .step-label {
  color: var(--color-primary);
  font-weight: var(--font-weight-medium);
}

/* ============================================
   结果展示系统
   ============================================ */

.result-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: var(--space-xl);
  margin-bottom: var(--space-lg);
  box-shadow: var(--shadow-md);
}

.result-amount {
  font-size: 72rpx;
  font-weight: var(--font-weight-bold);
  color: var(--color-primary);
  text-align: center;
  display: block;
  margin-bottom: var(--space-md);
}

.result-unit {
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-normal);
}

.result-label {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  text-align: center;
  display: block;
  margin-bottom: var(--space-xl);
}

.result-detail {
  border-top: 2rpx solid var(--color-border);
  padding-top: var(--space-lg);
}

.detail-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--space-sm) 0;
}

.detail-label {
  font-size: var(--font-size-base);
  color: var(--color-text-secondary);
}

.detail-value {
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-primary);
}

/* ============================================
   工具类
   ============================================ */

.text-center {
  text-align: center;
}

.text-primary {
  color: var(--color-primary);
}

.text-secondary {
  color: var(--color-text-secondary);
}

.text-hint {
  color: var(--color-text-hint);
}

.text-bold {
  font-weight: var(--font-weight-bold);
}

.mt-sm { margin-top: var(--space-sm); }
.mt-md { margin-top: var(--space-md); }
.mt-lg { margin-top: var(--space-lg); }
.mt-xl { margin-top: var(--space-xl); }

.mb-sm { margin-bottom: var(--space-sm); }
.mb-md { margin-bottom: var(--space-md); }
.mb-lg { margin-bottom: var(--space-lg); }
.mb-xl { margin-bottom: var(--space-xl); }

/* ============================================
   动画
   ============================================ */

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

@keyframes pulse {
  0%, 100% {
    opacity: 1;
  }
  50% {
    opacity: 0.7;
  }
}

.animate-fadeIn {
  animation: fadeIn var(--transition-normal);
}

.animate-slideUp {
  animation: slideUp var(--transition-normal);
}

.animate-pulse {
  animation: pulse 1.5s infinite;
}

/* ============================================
   无障碍
   ============================================ */

:focus {
  outline: 2rpx solid var(--color-primary);
  outline-offset: 4rpx;
}

/* 隐藏但保持可访问性 */
.sr-only {
  position: absolute;
  width: 1rpx;
  height: 1rpx;
  padding: 0;
  margin: -1rpx;
  overflow: hidden;
  clip: rect(0,0,0,0);
  white-space: nowrap;
  border: 0;
}
