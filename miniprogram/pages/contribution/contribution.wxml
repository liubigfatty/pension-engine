<!--pages/contribution/contribution.wxml - 缴费水平测算页-->
<view class="container">
  <view class="nav-bar">
    <text class="back-btn" bindtap="goBack">‹ 返回</text>
    <text class="nav-title">缴费水平测算</text>
    <view class="nav-placeholder"></view>
  </view>

  <scroll-view scroll-y class="scroll-area">
    <!-- 参保地区 -->
    <view class="card">
      <text class="section-title">参保信息</text>
      <view class="form-group">
        <text class="label">参保地区</text>
        <picker bindchange="onProvinceChange" range="{{provinceList}}">
          <view class="picker-value">
            {{selectedProvince ? selectedProvince.name : '请选择参保地区'}}
          </view>
        </picker>
      </view>
      <view class="form-group">
        <text class="label">退休地</text>
        <picker bindchange="onCityChange" range="{{cityList}}">
          <view class="picker-value">
            {{selectedCity ? selectedCity.name : '自动识别（默认全省）'}}
          </view>
        </picker>
      </view>
    </view>

    <!-- 人员信息 -->
    <view class="card">
      <text class="section-title">人员信息</text>
      <view class="form-group">
        <text class="label">姓名</text>
        <input class="input" placeholder="请输入姓名" bindinput="onNameInput" value="{{name}}" />
      </view>
      <view class="form-group">
        <text class="label">性别</text>
        <radio-group bindchange="onGenderChange">
          <label class="radio-label"><radio value="male" checked="{{gender === 'male'}}" /> 男</label>
          <label class="radio-label"><radio value="female" checked="{{gender === 'female'}}" /> 女</label>
        </radio-group>
      </view>
      <view class="form-group">
        <text class="label">出生年月</text>
        <picker mode="date" fields="month" bindchange="onBirthChange" value="{{birthDate}}">
          <view class="picker-value">{{birthDate || '请选择出生年月'}}</view>
        </picker>
      </view>
      <view class="form-group">
        <text class="label">参加工作时间</text>
        <picker mode="date" fields="month" bindchange="onWorkChange" value="{{workDate}}">
          <view class="picker-value">{{workDate || '请选择参加工作时间'}}</view>
        </picker>
      </view>
      <view class="form-group">
        <text class="label">平均缴费指数</text>
        <input class="input" type="digit" placeholder="如 1.0 表示按100%缴费" bindinput="onIndexInput" value="{{avgIndex}}" />
      </view>
    </view>

    <!-- 提交按钮 -->
    <view class="submit-section">
      <button class="submit-btn" bindtap="handleSubmit" loading="{{loading}}" disabled="{{loading}}">
        开始测算
      </button>
    </view>

    <!-- 结果展示 -->
    <view wx:if="{{result}}" class="card result-card">
      <text class="section-title">测算结果</text>
      <view class="result-row">
        <text class="result-label">平均缴费工资指数</text>
        <text class="result-value">{{result.metaData.avgIndex}}</text>
      </view>
      <view class="result-row">
        <text class="result-label">个人账户累计储存额</text>
        <text class="result-value">{{result.legal.personalAccount.balance}} 元</text>
      </view>
      <view class="result-row">
        <text class="result-label">个人账户养老金（月）</text>
        <text class="result-value">{{result.legal.personalAccount.amount}} 元</text>
      </view>
      <view class="result-row">
        <text class="result-label">视同缴费年限</text>
        <text class="result-value">{{result.legal.sightYears}} 年</text>
      </view>
      <view class="result-row">
        <text class="result-label">实际缴费年限</text>
        <text class="result-value">{{result.legal.actualYears}} 年</text>
      </view>
      <view class="result-row">
        <text class="result-label">累计缴费年限</text>
        <text class="result-value">{{result.legal.totalYears}} 年</text>
      </view>
    </view>

    <view class="footer">
      <text class="footer-text">测算结果仅供参考，实际以社保部门核定为准</text>
    </view>
  </scroll-view>
</view>
