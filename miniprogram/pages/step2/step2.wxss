/* pages/step2/step2.wxss - 卡片式表单样式 v4 */

/* ═══════════════════════════════════════════════════════
   表单卡片
   ═══════════════════════════════════════════════════════ */
.form-card {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 40rpx 36rpx 36rpx;
  box-shadow:
    0 4rpx 20rpx rgba(0,0,0,0.06),
    0 1rpx 4rpx rgba(0,0,0,0.04);
  margin-top: 24rpx;
}

/* 卡片标题 */
.form-card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 36rpx;
  padding-bottom: 28rpx;
  border-bottom: 1rpx solid #F0EDE8;
  display: block;
}

/* ═══════════════════════════════════════════════════════
   表单项 - 标签在上、输入框在下
   ═══════════════════════════════════════════════════════ */
.form-item {
  margin-bottom: 32rpx;
}

.form-item:last-of-type {
  margin-bottom: 40rpx;
}

/* 标签 */
.form-label {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  margin-bottom: 12rpx;
  display: block;
  font-weight: 500;
}

.form-required {
  color: var(--color-danger);
  margin-right: 4rpx;
}

/* ═══════════════════════════════════════════════════════
   选择器/下拉框 - 统一样式
   ═══════════════════════════════════════════════════════ */
.form-picker {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 26rpx 28rpx;
  background: var(--color-bg-input);
  border: 2rpx solid var(--color-border);
  border-radius: 48rpx;
  font-size: 30rpx;
  color: var(--color-text-primary);
  transition: all 0.2s ease;
}

.form-picker::after {
  /* 去掉微信默认边框 */
  border: none;
}

.form-picker:active {
  border-color: #8B7355;
  background: #FFFFFF;
}

.picker-content {
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.picker-content.placeholder {
  color: var(--color-text-hint);
}

.picker-content.warn {
  color: var(--color-danger);
}

.picker-content.readonly {
  color: var(--color-text-secondary);
  background: #F5F5F5;
  padding: 26rpx 28rpx;
  border-radius: 48rpx;
  border: 2rpx solid #E8E8E8;
}

/* 箭头图标 */
.picker-arrow {
  font-size: 20rpx;
  color: var(--color-text-hint);
  margin-left: 12rpx;
  flex-shrink: 0;
}

/* 全宽选择器 */
.form-picker-full {
  width: 100%;
}

/* ═══════════════════════════════════════════════════════
   单选按钮组 - 改为标签式
   ═══════════════════════════════════════════════════════ */
.radio-group {
  display: flex;
  gap: 20rpx;
  flex-wrap: wrap;
}

.radio-small .radio-item {
  min-width: auto;
  padding: 18rpx 28rpx;
  font-size: 26rpx;
}

.radio-item {
  min-width: 180rpx;
  padding: 22rpx 32rpx;
  background: var(--color-bg-input);
  border: 2rpx solid var(--color-border);
  border-radius: 48rpx;
  text-align: center;
  font-size: 28rpx;
  color: var(--color-text-secondary);
  transition: all 0.2s ease;
}

.radio-item:active {
  transform: scale(0.97);
}

.radio-item.active {
  background: linear-gradient(135deg, #8B7355, #A08566);
  color: #FFFFFF;
  border-color: transparent;
  box-shadow: 0 4rpx 14rpx rgba(139,115,85,0.25);
}

.radio-text {
  font-weight: 500;
}

/* ═══════════════════════════════════════════════════════
   提示文字
   ═══════════════════════════════════════════════════════ */
.form-hint {
  font-size: 24rpx;
  color: var(--color-text-hint);
  line-height: 1.5;
}

.form-hint-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 10rpx;
  padding-left: 6rpx;
}

.form-estimate {
  font-size: 24rpx;
  color: #8B7355;
  font-weight: 500;
  padding: 6rpx 20rpx;
  background: rgba(139,115,85,0.08);
  border-radius: 48rpx;
}

.hint-warn {
  color: var(--color-warning);
  background: rgba(212,168,75,0.08);
  padding: 10rpx 16rpx;
  border-radius: 48rpx;
  margin-top: 12rpx;
}

/* ═══════════════════════════════════════════════════════
   提交按钮 - 全宽圆角
   ═══════════════════════════════════════════════════════ */
.btn-submit {
  width: 100%;
  background: linear-gradient(135deg, #8B7355 0%, #A08566 100%);
  color: #FFFFFF !important;
  border: none !important;
  border-radius: 48rpx !important;
  padding: 28rpx 0;
  font-size: 32rpx !important;
  font-weight: 600 !important;
  letter-spacing: 4rpx;
  box-shadow: 0 6rpx 20rpx rgba(139,115,85,0.3);
  line-height: normal;
  margin-top: 8rpx;
}

.btn-submit::after {
  border: none !important;
}

.btn-submit:active {
  opacity: 0.9;
  transform: scale(0.98);
}

/* ═══════════════════════════════════════════════════════
   返回按钮（卡片底部）
   ═══════════════════════════════════════════════════════ */
.btn-back-wrap {
  margin-top: 28rpx;
  text-align: center;
}

.btn-back {
  display: inline-block;
  background: transparent;
  color: var(--color-text-hint);
  border: none !important;
  padding: 16rpx 32rpx;
  font-size: 26rpx !important;
  letter-spacing: 2rpx;
  line-height: normal;
}

.btn-back::after {
  border: none !important;
}

/* ═══════════════════════════════════════════════════════
   双指数省份并排显示
   ═══════════════════════════════════════════════════════ */
.double-index-row {
  display: flex;
  gap: 20rpx;
}

.flex-1 {
  flex: 1;
}

/* ═══════════════════════════════════════════════════════
   输入框 - 统一样式（用于 flex 布局中，
   ═══════════════════════════════════════════════════════ */
.input-wrap {
  position: relative;
  background: var(--color-bg-input);
  border: 2rpx solid var(--color-border);
  border-radius: 48rpx;
  padding: 0 28rpx;
  height: 88rpx;
  box-sizing: border-box;
}

.input-wrap:focus-within {
  border-color: #8B7355;
  background: #FFFFFF;
}

.input-field {
  width: 100%;
  height: 100%;
  font-size: 30rpx;
  color: var(--color-text-primary);
  background: transparent;
  line-height: 88rpx;
  padding-right: 70rpx;
  box-sizing: border-box;
}

.input-suffix {
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 26rpx;
  color: var(--color-text-hint);
  pointer-events: none;
}

/* ═══════════════════════════════════════════════════════
   小贴士弹窗
   ═══════════════════════════════════════════════════════ */
.tip-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.tip-popup {
  width: 620rpx;
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 48rpx 40rpx 36rpx;
  box-shadow: 0 16rpx 48rpx rgba(0,0,0,0.15);
}

.tip-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  text-align: center;
  margin-bottom: 32rpx;
}

.tip-content {
  margin-bottom: 36rpx;
}

.tip-line {
  font-size: 28rpx;
  color: #555;
  line-height: 1.8;
  margin-bottom: 8rpx;
}

.tip-highlight {
  color: #8B7355;
  font-weight: 600;
}

.tip-formula {
  background: #F5F3F0;
  border-radius: 48rpx;
  padding: 20rpx 24rpx;
  font-size: 26rpx;
  color: #8B7355;
  font-weight: 500;
  margin-top: 12rpx;
  text-align: center;
}

.tip-btn {
  background: linear-gradient(135deg, #8B7355, #A08566);
  color: #FFFFFF;
  border-radius: 48rpx;
  padding: 22rpx 0;
  text-align: center;
  font-size: 30rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
}

.tip-btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}
