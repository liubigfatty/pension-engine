/* pages/step2/step2.wxss - 布局优化版 */

.container {
  min-height: 100vh;
  background: #F5F3F0;
  padding: 24rpx 28rpx 60rpx;
  box-sizing: border-box;
}

/* ════════════════════════════
   步骤指示 - 与step1统一
   ════════════════════════════ */
.step-indicator {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 0 28rpx;
}

.step-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.step-dot {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #D5CEC3;
  color: #AAAAAA;
  font-size: 22rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.step-item.active .step-dot,
.step-item.done .step-dot {
  background: #8B7355;
  color: #FFFFFF;
}

.step-name {
  font-size: 24rpx;
  color: #AAAAAA;
}

.step-item.active .step-name {
  color: #8B7355;
  font-weight: 500;
}

.step-item.done .step-name {
  color: #8B7355;
}

.step-line {
  width: 60rpx;
  height: 3rpx;
  background: #D5CEC3;
  margin: 0 16rpx;
  margin-bottom: 2rpx;
}

/* ════════════════════════════
   表单卡片
   ════════════════════════════ */
.form-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 36rpx 32rpx 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

/* ════════════════════════════
   表单项
   ════════════════════════════ */
.form-item {
  margin-bottom: 28rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

/* 标签行 */
.form-label-row {
  display: flex;
  align-items: center;
  gap: 6rpx;
  margin-bottom: 10rpx;
}

.form-label {
  font-size: 27rpx;
  color: #555555;
  font-weight: 500;
}

.form-required {
  color: #C0392B;
  font-size: 24rpx;
}

.form-hint {
  font-size: 22rpx;
  color: #999999;
  margin-left: auto;
}

/* ════════════════════════════
   选择器 - 统一款式
   ════════════════════════════ */
.picker-box {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  background: #FAFAFA;
  border: 2rpx solid #E5E5EA;
  border-radius: 14rpx;
  font-size: 29rpx;
  color: #28292B;
  transition: all 0.2s ease;
}

.picker-box.selected {
  border-color: #8B7355;
  background: #FFFFFF;
}

.picker-box.placeholder text,
.picker-box .placeholder {
  color: #BBBBBB;
}

.picker-arrow {
  font-size: 18rpx;
  color: #CCCCCC;
  margin-left: 12rpx;
  flex-shrink: 0;
}

/* ════════════════════════════
   输入框
   ════════════════════════════ */
.input-row {
  display: flex;
  align-items: center;
  padding: 24rpx 28rpx;
  background: #FAFAFA;
  border: 2rpx solid #E5E5EA;
  border-radius: 14rpx;
  transition: all 0.2s ease;
}

.input-row:focus-within {
  border-color: #8B7355;
  background: #FFFFFF;
}

.input-box {
  flex: 1;
  font-size: 29rpx;
  color: #28292B;
  background: transparent;
}

/* 双输入框并排 */
.double-input-row {
  display: flex;
  gap: 16rpx;
}

.flex-1 {
  flex: 1;
}

/* ════════════════════════════
   提示文字
   ════════════════════════════ */
.form-hint {
  display: block;
  font-size: 23rpx;
  color: #999999;
  margin-top: 8rpx;
  padding-left: 4rpx;
}

/* ════════════════════════════
   计算按钮
   ════════════════════════════ */
.btn-primary {
  width: 100%;
  background: linear-gradient(135deg, #8B7355 0%, #A08566 100%);
  color: #FFFFFF !important;
  border: none !important;
  border-radius: 48rpx !important;
  padding: 26rpx 0;
  font-size: 30rpx !important;
  font-weight: 600 !important;
  letter-spacing: 4rpx;
  box-shadow: 0 6rpx 20rpx rgba(139,115,85,0.3);
  line-height: normal;
  margin-top: 12rpx;
}

.btn-primary::after {
  border: none !important;
}

/* ════════════════════════════
   返回按钮
   ════════════════════════════ */
.btn-wrap {
  margin-top: 28rpx;
  text-align: center;
}

.btn-back {
  display: inline-block;
  background: transparent;
  color: #999999;
  border: none !important;
  padding: 16rpx 32rpx;
  font-size: 26rpx !important;
  letter-spacing: 2rpx;
  line-height: normal;
}

.btn-back::after {
  border: none !important;
}
