/* pages/step2/step2.wxss - 优化版（更紧凑）*/

/* 表单组优化 */
.form-group {
  margin-bottom: var(--space-md);  /* 缩小margin */
}

/* 单选按钮组优化 */
.radio-group {
  display: flex;
  gap: var(--space-sm);
  flex-wrap: wrap;
}

.radio-item {
  flex: 1;
  min-width: 180rpx;  /* 缩小最小宽度 */
  background: var(--color-bg-input);
  border: 2rpx solid transparent;
  border-radius: var(--radius-round);
  padding: var(--space-sm) var(--space-md);  /* 缩小padding */
  text-align: center;
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
  transition: all var(--transition-fast);
}

.radio-item:active {
  background: #eee;
}

.radio-item.active {
  background: var(--color-primary);
  color: var(--color-text-white);
  border-color: var(--color-primary);
}

.radio-text {
  font-weight: var(--font-weight-medium);
}

/* 日期选择器行优化 */
.date-row {
  display: flex;
  gap: var(--space-sm);
  width: 100%;  /* 增加：占满父容器 */
}

.date-picker {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--space-sm) var(--space-md);
  border-radius: var(--radius-round);
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
  background: var(--color-bg-input);
  border: 2rpx solid transparent;
  transition: all var(--transition-fast);
}

.date-picker:active {
  background: #eee;
}

.date-picker.warn {
  border-color: var(--color-warning);
  background: #fffbf0;
}

/* 提示文字优化 */
.form-hint {
  font-size: var(--font-size-xs);
  color: var(--color-text-hint);
  margin-top: var(--space-xs);
  display: block;
  line-height: var(--line-height-normal);
}
