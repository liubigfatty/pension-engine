/* pages/step2/step2.wxss - 卡片式表单布局 v4 */

/* ════════════════════════════════
   卡片容器
   ════════════════════════════════ */
.form-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 40rpx 36rpx 36rpx;
  box-shadow:
    0 4rpx 20rpx rgba(0,0,0,0.06),
    0 1rpx 4rpx rgba(0,0,0,0.04);
  margin-top: 24rpx;
}

/* 卡片头部 - 编号+标题 */
.form-card-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 36rpx;
  padding-bottom: 28rpx;
  border-bottom: 1rpx solid #F0EDE8;
}

.form-card-num {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #8B7355, #A08566);
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.form-card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #28292B;
}

/* ════════════════════════════════
   表单项 - 标签在上、输入框在下
   ════════════════════════════════ */
.form-item {
  margin-bottom: 32rpx;
}

.form-item:last-of-type {
  margin-bottom: 40rpx;
}

/* 标签 */
.form-label {
  font-size: 28rpx;
  color: #555555;
  margin-bottom: 12rpx;
  display: block;
  font-weight: 500;
}

.form-required {
  color: #C0392B;
  margin-right: 4rpx;
}

/* ════════════════════════════════
   选择器/输入框 - 统一样式
   ════════════════════════════════ */
.form-picker {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 26rpx 28rpx;
  background: #FAFAFA;
  border: 2rpx solid #E5E5EA;
  border-radius: 16rpx;
  font-size: 30rpx;
  color: #28292B;
  transition: all 0.2s ease;
}

.form-picker::after {
  /* 覆盖微信默认边框 */
  border: none;
}

.form-picker:active {
  border-color: #8B7355;
  background: #FFFFFF;
}

.picker-content {
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.picker-content.placeholder {
  color: #BBBBBB;
}

.picker-content.warn {
  color: #C0392B;
}

/* 下拉箭头 */
.picker-arrow {
  font-size: 20rpx;
  color: #CCCCCC;
  margin-left: 12rpx;
  flex-shrink: 0;
}

/* 全宽选择器 */
.form-picker-full {
  width: 100%;
}

/* ════════════════════════════════
   单选按钮组 - 改为标签式
   ════════════════════════════════ */
.radio-group {
  display: flex;
  gap: 20rpx;
  flex-wrap: wrap;
}

.radio-small .radio-item {
  min-width: auto;
  padding: 18rpx 28rpx;
  font-size: 26rpx;
}

.radio-item {
  min-width: 180rpx;
  padding: 22rpx 32rpx;
  background: #FAFAFA;
  border: 2rpx solid #E5E5EA;
  border-radius: 16rpx;
  text-align: center;
  font-size: 28rpx;
  color: #555555;
  transition: all 0.2s ease;
}

.radio-item:active {
  transform: scale(0.97);
}

.radio-item.active {
  background: linear-gradient(135deg, #8B7355, #A08566);
  color: #FFFFFF;
  border-color: transparent;
  box-shadow: 0 4rpx 14rpx rgba(139,115,85,0.25);
}

.radio-text {
  font-weight: 500;
}

/* ════════════════════════════════
   提示文字
   ════════════════════════════════ */
.form-hint {
  display: block;
  font-size: 24rpx;
  color: #999999;
  margin-top: 10rpx;
  line-height: 1.5;
  padding-left: 6rpx;
}

.hint-warn {
  color: #D4A84B;
  background: rgba(212,168,75,0.08);
  padding: 10rpx 16rpx;
  border-radius: 8rpx;
  margin-top: 12rpx;
}

/* ════════════════════════════════
   提交按钮 - 全宽渐变
   ════════════════════════════════ */
.btn-submit {
  width: 100%;
  background: linear-gradient(135deg, #8B7355 0%, #A08566 100%);
  color: #FFFFFF !important;
  border: none !important;
  border-radius: 16rpx !important;
  padding: 28rpx 0;
  font-size: 32rpx !important;
  font-weight: 600 !important;
  letter-spacing: 4rpx;
  box-shadow: 0 6rpx 20rpx rgba(139,115,85,0.3);
  line-height: normal;
  margin-top: 8rpx;
}

.btn-submit::after {
  border: none !important;
}

.btn-submit:active {
  opacity: 0.9;
  transform: scale(0.98);
}

/* ════════════════════════════════
   返回按钮（卡片外面）
   ════════════════════════════════ */
.btn-back-wrap {
  margin-top: 28rpx;
  text-align: center;
}

.btn-back {
  display: inline-block;
  background: transparent;
  color: #999999;
  border: none !important;
  padding: 16rpx 32rpx;
  font-size: 26rpx !important;
  letter-spacing: 2rpx;
  line-height: normal;
}

.btn-back::after {
  border: none !important;
}

/* ═══════════════════════════════
   双指数并排显示
   ═══════════════════════════════ */
.double-index-row {
  display: flex;
  gap: 20rpx;
}

.flex-1 {
  flex: 1;
}

/* ═══════════════════════════════
   输入框样式增强
   ═══════════════════════════════ */
.input-row {
  display: flex;
  align-items: center;
  background: #FAFAFA;
  border: 2rpx solid #E5E5EA;
  border-radius: 16rpx;
  padding: 26rpx 28rpx;
  transition: all 0.2s ease;
}

.input-row:focus-within {
  border-color: #8B7355;
  background: #FFFFFF;
}

.input-box {
  flex: 1;
  font-size: 30rpx;
  color: #28292B;
  background: transparent;
}

.input-unit {
  font-size: 26rpx;
  color: #999999;
  margin-left: 12rpx;
  flex-shrink: 0;
}

/* ══════════════════════════
   小贴士弹窗
   ══════════════════════════ */
.tip-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.tip-popup {
  width: 620rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 48rpx 40rpx 36rpx;
  box-shadow: 0 16rpx 48rpx rgba(0,0,0,0.15);
}

.tip-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #28292B;
  text-align: center;
  margin-bottom: 32rpx;
}

.tip-content {
  margin-bottom: 36rpx;
}

.tip-line {
  font-size: 28rpx;
  color: #555;
  line-height: 1.8;
  margin-bottom: 8rpx;
}

.tip-highlight {
  color: #8B7355;
  font-weight: 600;
}

.tip-formula {
  background: #F5F3F0;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 26rpx;
  color: #8B7355;
  font-weight: 500;
  margin-top: 12rpx;
  text-align: center;
}

.tip-btn {
  background: linear-gradient(135deg, #8B7355, #A08566);
  color: #FFFFFF;
  border-radius: 16rpx;
  padding: 22rpx 0;
  text-align: center;
  font-size: 30rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
}

.tip-btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}
