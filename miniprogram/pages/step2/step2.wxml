<!--pages/step2/step2.wxml - 缴费信息页-->
<view class="step-container">
  <!-- 表单卡片 -->
  <view class="form-card">

    <!-- 计发基数（双基数省份显示选择，否则显示只读） -->
    <view class="form-item" wx:if="{{showBaseRate}}">
      <text class="form-label"><text class="form-required">*</text> 计发基数</text>
      <picker mode="selector" range="{{baseRateNames}}" value="{{baseRateIndex}}" bindchange="onBaseRateChange" class="form-picker">
        <view class="picker-content">{{baseRateNames[baseRateIndex] || '请选择计发基数'}}</view>
        <text class="picker-arrow">▼</text>
      </picker>
    </view>

    <!-- 缴费档次（灵活就业） -->
    <view class="form-item" wx:if="{{isFlexible}}">
      <text class="form-label"><text class="form-required">*</text> 缴费档次</text>
      <picker mode="selector" range="{{levelNames}}" value="{{levelIndex}}" bindchange="onLevelChange" class="form-picker">
        <view class="picker-content {{levelIndex >= 0 ? '' : 'placeholder'}}">{{levelIndex >= 0 ? levelNames[levelIndex] : '请选择缴费档次'}}</view>
        <text class="picker-arrow">▼</text>
      </picker>
    </view>

    <!-- 本人平均缴费指数（常显） -->
    <view class="form-item">
      <text class="form-label">本人平均缴费指数</text>
      <view class="input-wrap">
        <input class="input-field" type="digit" value="{{averageIndexInput}}" placeholder="如不清楚可留空，系统将自动估算" bindinput="onIndexInput"/>
        <text class="input-suffix">指数</text>
      </view>
      <text class="form-hint">可从社保查询，留空则系统自动估算</text>
    </view>

    <!-- 双指数省份（浙江/广东/陕西）- 并排显示 -->
    <view class="form-item" wx:if="{{showDoubleIndex}}">
      <text class="form-label">双指数省份（过渡性养老金指数）</text>
      <view class="double-index-row">
        <view class="input-wrap flex-1">
          <input class="input-field" type="digit" value="{{transIndexInput}}" placeholder="过渡性指数" bindinput="onTransIndexInput"/>
          <text class="input-suffix">过渡指数</text>
        </view>
        <view class="input-wrap flex-1">
          <input class="input-field" type="digit" value="{{oldIndexInput}}" placeholder="老办法指数" bindinput="onOldIndexInput"/>
          <text class="input-suffix">老办法指数</text>
        </view>
      </view>
    </view>

    <!-- 个人账户余额 -->
    <view class="form-item">
      <text class="form-label">个人账户余额</text>
      <view class="input-wrap">
        <input class="input-field" type="digit" value="{{accountBalanceInput}}" placeholder="如不清楚可留空，系统将自动估算" bindinput="onBalanceInput"/>
        <text class="input-suffix">元</text>
      </view>
      <view class="form-hint-row">
        <text class="form-hint" bindtap="onShowBalanceTip">不清楚可查看【小贴士】</text>
        <text class="form-estimate" bindtap="onEstimateBalance">估算余额</text>
      </view>
    </view>

    <!-- 计算按钮 -->
    <button class="btn-submit" bindtap="onCalculate">计算养老金</button>
  </view>

  <!-- 返回按钮 -->
  <view class="btn-back-wrap">
    <button class="btn-back" bindtap="onPrev">← 返回上一步</button>
  </view>

  <!-- 小贴士弹窗 -->
  <view class="tip-mask" wx:if="{{showBalanceTip}}" bindtap="onCloseBalanceTip">
    <view class="tip-popup" catchtap="stopProp">
      <view class="tip-title">💡 个人账户余额小贴士</view>
        <view class="tip-content">
          <view class="tip-line">• 个人账户余额 = 历年个人缴费累计本息</view>
          <view class="tip-line">• 个人缴费比例一般为缴费基数的 <text class="tip-highlight">8%</text></view>
          <view class="tip-line">• 灵活就业人员缴费比例一般为 <text class="tip-highlight">20%</text>（其中8%进入个人账户）</view>
          <view class="tip-line">• 可登录社保APP或到社保大厅查询准确余额</view>
          <view class="tip-line">• 如不清楚，系统将自动估算（基于历年缴费基数和记账利率）</view>
        </view>
      <view class="tip-btn" bindtap="onCloseBalanceTip">知道了</view>
    </view>
  </view>
</view>
