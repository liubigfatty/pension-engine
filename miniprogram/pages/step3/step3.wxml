<!--pages/step3/step3.wxml - 优化版（去掉多余提示）-->
<view class="step-container">
  <!-- 进度条 -->
  <view class="progress-bar">
    <view class="progress-step done">
      <view class="step-dot">1</view>
      <text class="step-label">选择地区</text>
    </view>
    <view class="step-line active"></view>
    <view class="progress-step done">
      <view class="step-dot">2</view>
      <text class="step-label">个人信息</text>
    </view>
    <view class="step-line active"></view>
    <view class="progress-step active">
      <view class="step-dot">3</view>
      <text class="step-label">缴费信息</text>
    </view>
  </view>

  <!-- 标题 -->
  <text class="page-title">缴费信息</text>
  <text class="page-desc">请填写缴费相关信息</text>

  <!-- 平均缴费指数 -->
  <view class="form-group">
    <text class="form-label"><text class="form-required">*</text> 平均缴费指数</text>
    <view class="index-grid">
      <view
        wx:for="{{indexOptions}}"
        wx:key="value"
        class="index-item {{selectedIndex === index && !useCustomIndex ? 'active' : ''}}"
        data-idx="{{index}}"
        bindtap="onIndexSelect"
      >{{item.label}}</view>
    </view>
    <view class="custom-index" bindtap="onCustomIndexTap">
      <text class="{{useCustomIndex ? 'active' : ''}}">{{useCustomIndex ? '✏️ 手动输入中...' : '✏️ 手动输入'}}</text>
    </view>
    <input
      wx:if="{{useCustomIndex}}"
      class="custom-input"
      type="digit"
      placeholder="0.6 ~ 3.0"
      value="{{customIndex}}"
      bindinput="onIndexInput"
    />
  </view>

  <!-- 个人账户余额 -->
  <view class="form-group">
    <text class="form-label"><text class="form-required">*</text> 个人账户余额（元）</text>
    <input
      class="balance-input"
      type="digit"
      placeholder="请输入个人账户余额"
      value="{{accountBalance}}"
      bindinput="onBalanceInput"
    />
  </view>

  <!-- 加发项（根据省份动态显示） -->
  <view class="form-group" wx:if="{{hasExtra}}">
    <text class="form-label">{{extraLabel || '加发项'}}</text>
    <view class="form-hint" wx:if="{{extraType === 'extra_pension'}}">视同缴费年限 ≥ 20年可触发增发</view>
    <view class="form-hint" wx:if="{{extraType === 'special_addition'}}">该省份有特殊加发项</view>
  </view>

  <!-- 计算按钮 -->
  <view class="btn-area">
    <button class="btn-secondary" bindtap="onPrev">上一步</button>
    <button class="btn-calculate" bindtap="onCalculate">计算养老金</button>
  </view>
</view>
