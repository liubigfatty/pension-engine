/* pages/step3/step3.wxss - 优化版（更紧凑）*/

/* 摘要卡片优化 */
.summary-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: var(--space-md) var(--space-lg);  /* 缩小padding */
  margin-bottom: var(--space-md);
  box-shadow: var(--shadow-sm);
  border: 1rpx solid var(--color-border);
}

.summary-row {
  display: flex;
  justify-content: space-between;
  padding: var(--space-xs) 0;  /* 缩小padding */
  border-bottom: 1rpx solid #eee;
}

.summary-row:last-child {
  border-bottom: none;
}

.summary-label {
  font-size: var(--font-size-xs);  /* 缩小字号 */
  color: var(--color-text-hint);
}

.summary-value {
  font-size: var(--font-size-sm);  /* 缩小字号 */
  color: var(--color-text-primary);
  font-weight: var(--font-weight-medium);
}

/* 指数选择网格优化 */
.index-grid {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-sm);  /* 缩小间距 */
  margin-bottom: var(--space-md);
}

.index-item {
  width: calc(50% - var(--space-sm) / 2);
  text-align: center;
  padding: var(--space-sm) 0;  /* 缩小padding */
  border-radius: var(--radius-lg);
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
  background: var(--color-bg-input);
  border: 2rpx solid transparent;
  box-sizing: border-box;
  transition: all var(--transition-fast);
}

.index-item:active {
  background: #eee;
}

.index-item.active {
  color: var(--color-text-white);
  background: var(--color-primary);
  border-color: var(--color-primary);
  font-weight: var(--font-weight-bold);
}

/* 自定义输入按钮优化 */
.custom-index {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-sm);
  padding: var(--space-sm) var(--space-md);  /* 缩小padding */
  border-radius: var(--radius-lg);
  font-size: var(--font-size-sm);  /* 缩小字号 */
  color: var(--color-primary);
  background: var(--color-primary-light);
  border: 2rpx dashed var(--color-primary);
  margin-top: var(--space-sm);
  transition: all var(--transition-fast);
}

.custom-index:active {
  background: #d4edda;
}

.custom-input {
  margin-top: var(--space-md);
  padding: var(--space-lg) var(--space-md);  /* 增大padding，避免数字被遮挡 */
  border-radius: var(--radius-lg);
  font-size: var(--font-size-md);  /* 增大字号 */
  color: var(--color-text-primary);
  background: var(--color-bg-card);
  border: 2rpx solid var(--color-primary);
  width: 100%;
  height: 88rpx;  /* 固定高度 */
  line-height: 1.4;
  box-sizing: border-box;
}

.custom-input::placeholder {
  color: var(--color-text-hint);
  font-size: var(--font-size-sm);
}

/* 账户余额输入优化 */
.balance-input {
  padding: var(--space-lg) var(--space-md);  /* 增大padding，避免数字被遮挡 */
  border-radius: var(--radius-round);
  font-size: var(--font-size-md);  /* 增大字号，数字更清晰 */
  color: var(--color-text-primary);
  background: var(--color-bg-input);
  border: 2rpx solid transparent;
  width: 100%;
  height: 88rpx;  /* 固定高度，防止截断 */
  line-height: 1.4;
  box-sizing: border-box;
  transition: all var(--transition-fast);
}

.balance-input:focus {
  background: var(--color-bg-card);
  border-color: var(--color-border-focus);
}

.balance-input::placeholder {
  color: var(--color-text-hint);
}

/* 计算按钮优化 */
.btn-area {
  display: flex;
  gap: var(--space-md);
  margin-top: var(--space-xl);
}

.btn-area .btn-secondary {
  width: 200rpx !important;  /* 固定宽度，不撑满 */
  flex-shrink: 0;
  padding: var(--space-md) 0;
  font-size: var(--font-size-base);
}

.btn-calculate {
  flex: 1;  /* 占据剩余空间 */
  background: linear-gradient(135deg, #07c160 0%, #06ae56 100%);
  color: var(--color-text-white);
  border: none;
  border-radius: var(--radius-round);
  padding: var(--space-md) 0;
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-medium);
  letter-spacing: 4rpx;
  position: relative;
  overflow: hidden;
  box-shadow: var(--shadow-primary);
  transition: all var(--transition-normal);
}

.btn-calculate:active {
  transform: scale(0.98);
  box-shadow: var(--shadow-sm);
}

.btn-calculate.disabled,
.btn-calculate[disabled] {
  background: #c8d1ca;  /* 明显的灰色，不是不可见 */
  color: #ffffff;  /* 白色文字在灰底上清晰可见 */
  box-shadow: none;
  opacity: 0.85;  /* 轻微透明度，但仍清晰可见 */
}
