/* pages/step3/step3.wxss */

.container {
  padding: 40rpx 32rpx;
  padding-bottom: 120rpx;
}

/* 进度 */
.progress {
  display: flex; align-items: center; justify-content: center; margin-bottom: 48rpx;
}
.progress-dot { width: 24rpx; height: 24rpx; border-radius: 50%; background: #e0e0e0; }
.progress-dot.done { background: #07c160; }
.progress-dot.active { background: #07c160; }
.progress-line { width: 80rpx; height: 4rpx; background: #e0e0e0; margin: 0 12rpx; }
.progress-line.done { background: #07c160; }
.progress-line.active { background: #07c160; }

/* 标题 */
.page-title { display: block; font-size: 44rpx; font-weight: bold; color: #1a1a1a; text-align: center; }
.page-desc { display: block; font-size: 26rpx; color: #999; text-align: center; margin-top: 12rpx; margin-bottom: 36rpx; }

/* 摘要卡片 */
.summary-card {
  background: #f8f9fa; border-radius: 16rpx; padding: 28rpx; margin-bottom: 36rpx;
}
.summary-row {
  display: flex; justify-content: space-between; padding: 10rpx 0;
  border-bottom: 1rpx solid #eee;
}
.summary-row:last-child { border-bottom: none; }
.summary-label { font-size: 27rpx; color: #888; }
.summary-value { font-size: 27rpx; color: #333; font-weight: 500; }

/* 表单 */
.form-group { margin-bottom: 32rpx; }
.form-label { font-size: 30rpx; color: #333; font-weight: 500; margin-bottom: 16rpx; display: block; }
.required { color: #e74c3c; font-weight: bold; }

/* 指数选择网格 */
.index-grid {
  display: flex; flex-wrap: wrap; gap: 16rpx; margin-bottom: 16rpx;
}
.index-item {
  width: calc(33.33% - 12rpx); text-align: center; padding: 20rpx 0; border-radius: 12rpx;
  font-size: 30rpx; color: #666; background: #f7f8fa; border: 2rpx solid transparent;
  box-sizing: border-box;
}
.index-item.active { color: #fff; background: #07c160; border-color: #07c160; font-weight: 600; }

/* 自定义输入 */
.custom-input-btn {
  display: flex; align-items: center; justify-content: center; gap: 8rpx;
  padding: 18rpx 0; border-radius: 12rpx; font-size: 26rpx; color: #999;
  background: transparent; border: 2rpx dashed #ddd;
}
.custom-input-btn .arrow { font-size: 32rpx; }
.custom-input-wrap { margin-top: 16rpx; }
.custom-input {
  padding: 22rpx 24rpx; border-radius: 12rpx; font-size: 30rpx;
  background: #f7f8fa; border: 2rpx solid #07c160;
}

/* 账户余额 */
.balance-row { position: relative; }
.balance-input {
  padding: 24rpx 28rpx; border-radius: 14rpx; font-size: 32rpx; color: #333;
  background: #f7f8fa; border: 2rpx solid transparent;
}
.balance-input:focus { border-color: #07c160; }
.balance-hint {
  position: absolute; right: 28rpx; top: 50%; transform: translateY(-50%);
  padding: 8rpx 20rpx; border-radius: 8rpx; font-size: 24rpx; color: #07c160;
  background: #f0faf5; white-space: nowrap;
}
.balance-note { font-size: 24rpx; color: #999; margin-top: 12rpx; }

/* 加发项 */
.extra-item {
  display: flex; align-items: center; justify-content: space-between;
  padding: 20rpx 0; border-bottom: 1rpx solid #f0f0f0;
}
.extra-label { font-size: 28rpx; color: #555; }
.extra-input {
  width: 200rpx; text-align: right; padding: 12rpx 16rpx; border-radius: 8rpx;
  font-size: 28rpx; background: #f7f8fa; border: 2rpx solid #eee;
}

/* 按钮 */
.btn-area {
  display: flex; gap: 20rpx; margin-top: 48rpx;
  position: fixed; bottom: 0; left: 32rpx; right: 32rpx;
  background: linear-gradient(transparent, rgba(255,255,255,0.95));
  padding: 24rpx 0; padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}
.btn-prev {
  width: 25%; background: #fff; color: #666; border: 2rpx solid #ddd;
  border-radius: 50rpx; padding: 24rpx 0; font-size: 28rpx;
}
.btn-prev::after { border: none; }
.btn-calc {
  flex: 1; background: #07c160; color: #fff; border: none;
  border-radius: 50rpx; padding: 24rpx 0; font-size: 32rpx; font-weight: 600;
  letter-spacing: 4rpx;
}
.btn-calc[disabled] { background: #ccc; }
.btn-calc::after { border: none; }
.btn-calc.loading { opacity: 0.7; }
