/* pages/result/result.wxss - 增强版 v3（精致金融风格） */

.container {
  padding: 32rpx;
  background: #F5F3F0;  /* 正元暖白 - 页面底 */
  min-height: 100vh;
}

/* ═════════════ 金额主卡片（精致渐变） ═════════════ */
.amount-card {
  background: linear-gradient(165deg, #171717 0%, #2A2A2A 100%);  /* 精致深色渐变 */
  border-radius: 32rpx;  /* 更大的圆角 */
  padding: 56rpx 40rpx 44rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 24rpx;
  box-shadow: 
    0 8rpx 32rpx rgba(40,41,43,0.25),  /* 主阴影 */
    0 2rpx 8rpx rgba(40,41,43,0.15),   /* 次阴影 */
    inset 0 1rpx 0 rgba(139,115,85,0.12);  /* 顶部高光 */
  position: relative;
  overflow: hidden;
}

/* 添加 subtle 纹理背景 */
.amount-card::before {
  content: '';
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle at 30% 40%, rgba(139,115,85,0.06) 0%, transparent 60%);
  pointer-events: none;
}

.amount-card-label {
  font-size: 28rpx;
  color: rgba(139,115,85,0.9);  /* 正元光 - 半透明 */
  letter-spacing: 2rpx;
  font-weight: 400;
  margin-bottom: 8rpx;
}

.amount-card-row {
  display: flex;
  align-items: baseline;
  justify-content: center;
  margin: 24rpx 0 16rpx;
}

.amount-card-symbol {
  font-size: 48rpx;
  color: #B8977D;  /* 正元光 - 金色 */
  font-weight: 600;
  margin-right: 8rpx;
}

.amount-card-value {
  font-size: 96rpx;  /* 更大的金额 */
  color: #B8977D;  /* 正元光 - 金色 */
  font-weight: 700;  /* 更粗的字重 */
  line-height: 1;
  letter-spacing: -3rpx;  /* 更紧凑的字母间距 */
  font-family: -apple-system, 'Helvetica Neue', 'PingFang SC', sans-serif;
}

/* 退休信息标签 */
.retire-tag {
  margin-top: 24rpx;
  background: rgba(139,115,85,0.12);  /* 半透明金色 */
  border-radius: 48rpx;
  padding: 12rpx 32rpx;
  border: 1rpx solid rgba(139,115,85,0.18);  /* 精致边框 */
}

.retire-tag text {
  font-size: 26rpx;
  color: rgba(139,115,85,0.95);  /* 正元光 */
  font-weight: 500;
}

/* 地区标签 */
.region-text {
  display: block;
  text-align: center;
  font-size: 26rpx;
  color: #6C584B;  /* Warm Taupe - 暖棕 */
  margin: 8rpx 0 28rpx;
  letter-spacing: 1rpx;
}

/* ═════════════ 通用卡片样式（增强） ═════════════ */
.card {
  background: #F4F0E8;  /* Creamy Off-White - 暖白 */
  border-radius: 32rpx;  /* 统一大卡片圆角 */
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 
    0 4rpx 16rpx rgba(40,41,43,0.06),  /* 主阴影 */
    0 1rpx 4rpx rgba(40,41,43,0.04);   /* 次阴影 */
  border: 1rpx solid rgba(213,206,195,0.5);  /* 精致富质感边框 */
}

.card-body {
  padding: 20rpx 36rpx;  /* 统一行间距 */
}

.card-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;  /* 统一行间距 */
  min-height: 56rpx;
}

.card-label {
  font-size: 28rpx;
  color: #6C584B;  /* Warm Taupe - 暖棕 */
  font-weight: 400;
  letter-spacing: 0.5rpx;
}

.card-value {
  font-size: 32rpx;  /* 更大的数值 */
  color: #171717;  /* Deep Charcoal - 深色正文 */
  font-weight: 600;
  letter-spacing: 0.5rpx;
}

.card-value-blue {
  color: #8B7355;  /* 正元金 */
  font-weight: 600;
}

.card-divider {
  height: 1rpx;
  background: linear-gradient(90deg, transparent 0%, #E0D8CC 15%, #E0D8CC 85%, transparent 100%);  /* 渐变分割线 */
  margin: 0;
}

/* ═════════════ 按钮区域（增强） ═════════════ */
.btn-area {
  padding: 16rpx 0 24rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 12rpx;
}

.btn-share {
  width: 100%;
  background: linear-gradient(135deg, #8B7355 0%, #A08566 100%);
  color: #FFFFFF !important;
  border: none;
  border-radius: 48rpx;
  padding: 28rpx 0;
  font-size: 30rpx;
  font-weight: 600;
  letter-spacing: 4rpx;
  box-shadow: 0 8rpx 24rpx rgba(139,115,85,0.35);
}

.btn-share::after { border: none; }

.btn-report {
  width: 100%;
  background: #F4F0E8;
  color: #8B7355 !important;
  border: 2rpx solid #8B7355;
  border-radius: 48rpx;
  padding: 28rpx 0;
  font-size: 30rpx;
  font-weight: 600;
  letter-spacing: 4rpx;
}

.btn-report::after { border: none; }

/* 分享查看模式："我也来算一下"按钮 */
.btn-calculate {
  width: 100%;
  background: linear-gradient(135deg, #8B7355 0%, #A08566 100%);
  color: #FFFFFF !important;
  border: none;
  border-radius: 48rpx;
  padding: 28rpx 0;
  font-size: 32rpx;
  font-weight: 600;
  letter-spacing: 4rpx;
  box-shadow: 0 8rpx 24rpx rgba(139,115,85,0.35);
}

.btn-calculate::after { border: none; }

.error-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 48rpx 80rpx;
  min-height: 60vh;
  text-align: center;
}

.error-icon { font-size: 80rpx; margin-bottom: 32rpx; }

.error-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #171717;  /* Deep Charcoal - 深色正文 */
  margin-bottom: 24rpx;
}

.error-desc {
  font-size: 28rpx;
  color: #6C584B;  /* Warm Taupe - 暖棕 */
  line-height: 1.6;
  margin-bottom: 48rpx;
}

/* ═════════════ 声明 ═════════════ */
.disclaimer {
  padding: 32rpx 16rpx 56rpx;
  text-align: center;
}

.disclaimer text {
  font-size: 24rpx;
  color: #AAAAAA;
/* ════════════ 分享预览弹窗 ══════════ */
.share-preview-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.55);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.share-preview-body {
  width: 100%;
  max-height: 90vh;
  background: #F5F3F0;
  border-radius: 32rpx 32rpx 0 0;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.share-preview-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #E0D8CC;
}

.share-preview-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #171717;
}

.share-preview-close {
  font-size: 40rpx;
  color: #6C584B;
  padding: 8rpx 16rpx;
}

.share-preview-scroll {
  flex: 1;
  max-height: 60vh;
  padding: 24rpx 32rpx;
}

.share-preview-img {
  width: 100%;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(40,41,43,0.10);
}

.share-preview-footer {
  display: flex;
  gap: 20rpx;
  padding: 24rpx 32rpx 48rpx;
  border-top: 1rpx solid #E0D8CC;
}

.share-preview-btn {
  flex: 1;
  padding: 24rpx 0;
  border-radius: 48rpx;
  font-size: 28rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  border: none;
}

.share-preview-btn::after { border: none; }

.share-preview-btn.save {
  background: #F4F0E8;
  color: #8B7355;
  border: 2rpx solid #8B7355;
}

.share-preview-btn.share {
  background: linear-gradient(135deg, #8B7355 0%, #A08566 100%);
  color: #FFFFFF;
  box-shadow: 0 8rpx 24rpx rgba(139,115,85,0.35);
}
