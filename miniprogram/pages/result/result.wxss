/* pages/result/result.wxss - 使用全局设计系统 v2.0 */

.container {
  padding: 0;
  background: var(--color-bg-page);
  min-height: 100vh;
}

/* 头部 */
.result-header {
  background: linear-gradient(135deg, var(--color-primary), #05a854);
  padding: var(--space-xxl) var(--space-xl) var(--space-xl);
  color: var(--color-text-white);
}

.result-title {
  display: block;
  font-size: var(--font-size-lg);  /* 38rpx */
  font-weight: var(--font-weight-bold);
  letter-spacing: 2rpx;
}

.result-subtitle {
  display: block;
  font-size: var(--font-size-sm);  /* 26rpx */
  opacity: 0.8;
  margin-top: var(--space-xs);
}

.total-amount {
  text-align: center;
  margin-top: var(--space-xl);
}

.total-label {
  display: block;
  font-size: var(--font-size-sm);  /* 26rpx */
  opacity: 0.85;
}

.total-row {
  display: flex;
  align-items: baseline;
  justify-content: center;
  margin-top: var(--space-md);
}

.total-currency {
  font-size: var(--font-size-xl);  /* 44rpx */
  margin-right: var(--space-xs);
}

.total-value {
  font-size: 88rpx;  /* 保持大字体 */
  font-weight: var(--font-weight-bold);
  line-height: 1;
}

.total-unit {
  display: block;
  font-size: var(--font-size-sm);  /* 24rpx */
  opacity: 0.7;
  margin-top: var(--space-xs);
}

/* 退休信息 */
.retire-info {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-md);
  margin-top: var(--space-lg);
  padding: var(--space-md) var(--space-lg);
  background: rgba(255,255,255,0.15);
  border-radius: var(--radius-round);
  align-self: flex-start;
}

.retire-label {
  font-size: var(--font-size-base);  /* 28rpx */
  font-weight: var(--font-weight-bold);
}

.retire-note {
  font-size: var(--font-size-xs);  /* 22rpx */
  opacity: 0.8;
}

/* 区块 */
.section {
  margin: var(--space-lg);
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}

.section-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--space-lg) var(--space-xl);
  font-size: var(--font-size-md);  /* 30rpx */
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
  border-bottom: 1rpx solid #f0f0f0;
}

.toggle-icon {
  font-size: var(--font-size-base);  /* 26rpx */
  color: var(--color-primary);
  font-weight: var(--font-weight-normal);
}

/* 养老金列表 */
.pension-list {
  padding: var(--space-xs) 0;
}

.pension-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--space-md) var(--space-xl);
}

.pension-item.main {
  background: #f8fdf9;
  margin: var(--space-md) var(--space-lg);
  border-radius: var(--radius-md);
}

.pension-label {
  font-size: var(--font-size-base);  /* 29rpx */
  color: var(--color-text-secondary);
  display: flex;
  align-items: center;
  gap: var(--space-sm);
}

.pension-value {
  font-size: var(--font-size-md);  /* 32rpx */
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
}

.main-val {
  font-size: var(--font-size-lg);  /* 38rpx */
  color: var(--color-primary);
}

.dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  display: inline-block;
}

.dot-blue { background: #3498db; }
.dot-green { background: #27ae60; }
.dot-orange { background: #e67e22; }
.dot-red { background: #e74c3c; }

/* 详细参数 */
.detail-list {
  padding: var(--space-xs) 0;
}

.detail-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--space-md) var(--space-xl);
  border-bottom: 1rpx solid #f5f5f5;
}

.detail-item:last-child {
  border-bottom: none;
}

.detail-label {
  font-size: var(--font-size-base);  /* 27rpx */
  color: var(--color-text-secondary);
}

.detail-value {
  font-size: var(--font-size-base);  /* 28rpx */
  color: var(--color-text-primary);
  font-weight: var(--font-weight-medium);
}

.detail-value.highlight {
  color: #e67e22;
  font-weight: var(--font-weight-bold);
  font-size: var(--font-size-md);  /* 30rpx */
}

/* 按钮区域 */
.btn-area {
  padding: var(--space-xl) var(--space-lg);
  display: flex;
  gap: var(--space-md);
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  margin: var(--space-lg);
  box-shadow: var(--shadow-sm);
}

.btn-share {
  flex: 1.2;
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
  color: var(--color-text-white);
  border: none;
  border-radius: var(--radius-round);
  padding: var(--space-md) 0;
  font-size: var(--font-size-base);  /* 30rpx */
  font-weight: var(--font-weight-bold);
  box-shadow: var(--shadow-primary);
}

.btn-share::after {
  border: none;
}

.btn-save {
  flex: 1;
  background: var(--color-bg-card);
  color: var(--color-primary);
  border: 2rpx solid var(--color-primary);
  border-radius: var(--radius-round);
  padding: var(--space-md) 0;
  font-size: var(--font-size-base);  /* 28rpx */
  font-weight: var(--font-weight-medium);
}

.btn-save::after {
  border: none;
}

.btn-recalc {
  flex: 0.8;
  background: var(--color-bg-input);
  color: var(--color-text-hint);
  border: none;
  border-radius: var(--radius-round);
  padding: var(--space-md) 0;
  font-size: var(--font-size-base);  /* 28rpx */
}

.btn-recalc::after {
  border: none;
}

/* 数据异常提示 */
.error-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx var(--space-xxl) 80rpx;
  min-height: 60vh;
  text-align: center;
}

.error-icon {
  font-size: 80rpx;
  margin-bottom: var(--space-xl);
}

.error-title {
  font-size: var(--font-size-xl);
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
  margin-bottom: var(--space-lg);
}

.error-desc {
  font-size: var(--font-size-base);
  color: var(--color-text-hint);
  line-height: var(--line-height-normal);
  margin-bottom: var(--space-xxl);
}

/* 声明 */
.disclaimer {
  padding: var(--space-lg) var(--space-xxl) var(--space-xxl);
  text-align: center;
}

.disclaimer text {
  font-size: var(--font-size-xs);  /* 23rpx */
  color: var(--color-text-hint);
}
