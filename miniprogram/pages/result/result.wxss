/* result.wxss - 结果页 */
.container {
  background: #f8f9fa;
  min-height: 100vh;
  padding-bottom: 120rpx;
}

.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  background: #1e3a5f;
  color: #fff;
}

.back-btn {
  font-size: 32rpx;
  color: #fff;
  cursor: pointer;
}

.nav-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}

.nav-placeholder {
  width: 120rpx;
}

.scroll-area {
  padding: 24rpx;
}

.main-card {
  background: linear-gradient(135deg, #1e3a5f 0%, #2563eb 100%);
  border-radius: 32rpx;
  padding: 64rpx 32rpx;
  text-align: center;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(30,58,95,0.3);
}

.main-label {
  font-size: 28rpx;
  color: rgba(255,255,255,0.9);
  display: block;
  margin-bottom: 16rpx;
}

.main-amount {
  font-size: 72rpx;
  font-weight: 700;
  color: #fff;
  display: block;
}

.main-unit {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  display: block;
  margin-top: 12rpx;
}

.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.06);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1e3a5f;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #e5e7eb;
  display: block;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #f0f0f0;
}

.detail-row:last-child {
  border-bottom: none;
}

.detail-name {
  font-size: 28rpx;
  color: #4b5563;
}

.detail-amount {
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
}

.param-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 2rpx solid #f0f0f0;
}

.param-label {
  font-size: 26rpx;
  color: #6b7280;
}

.param-value {
  font-size: 26rpx;
  font-weight: 500;
  color: #111827;
}

.flex-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 0;
}

.flex-item {
  text-align: center;
  flex: 1;
}

.flex-label {
  font-size: 24rpx;
  color: #6b7280;
  display: block;
  margin-bottom: 12rpx;
}

.flex-date {
  font-size: 26rpx;
  color: #374151;
  display: block;
  margin-bottom: 16rpx;
}

.flex-amount {
  font-size: 48rpx;
  font-weight: 700;
  color: #111827;
  display: block;
}

.flex-divider {
  font-size: 24rpx;
  color: #9ca3af;
  padding: 0 24rpx;
}

.flex-note {
  font-size: 22rpx;
  color: #6b7280;
  text-align: center;
  padding-top: 16rpx;
  border-top: 2rpx solid #f0f0f0;
}

.export-card {
  background: #f0f4f8;
  text-align: center;
  padding: 40rpx;
}

.export-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1e3a5f;
  display: block;
  margin-bottom: 12rpx;
}

.export-desc {
  font-size: 24rpx;
  color: #6b7280;
  display: block;
  margin-bottom: 24rpx;
}

.export-btn {
  background: #10b981;
  color: #fff;
  border: none;
  border-radius: 16rpx;
  padding: 24rpx 48rpx;
  font-size: 30rpx;
  font-weight: 500;
}
