<!--result.wxml - 测算结果页-->
<view class="container">
  <view class="nav-bar">
    <text class="back-btn" bindtap="goBack">‹ 返回</text>
    <text class="nav-title">测算结果</text>
    <view class="nav-placeholder"></view>
  </view>

  <scroll-view scroll-y class="scroll-area">
    <!-- 主结果卡 -->
    <view class="main-card">
      <text class="main-label">基本养老金总额</text>
      <text class="main-amount">{{legalTotal}}</text>
      <text class="main-unit">元/月</text>
    </view>

    <!-- 四部分明细 -->
    <view class="card">
      <text class="section-title">养老金构成</text>
      
      <view class="detail-row">
        <text class="detail-name">基础养老金</text>
        <text class="detail-amount">{{legalBasicPension}}</text>
      </view>
      <view class="detail-row">
        <text class="detail-name">增发基础养老金</text>
        <text class="detail-amount">{{legalExtraPension}}</text>
      </view>
      <view class="detail-row">
        <text class="detail-name">个人账户养老金</text>
        <text class="detail-amount">{{legalPersonalPension}}</text>
      </view>
      <view class="detail-row">
        <text class="detail-name">过渡性养老金</text>
        <text class="detail-amount">{{legalTransPension}}</text>
      </view>
    </view>

    <!-- 关键参数 -->
    <view class="card">
      <text class="section-title">关键参数</text>
      <view class="param-row">
        <text class="param-label">退休日期</text>
        <text class="param-value">{{legalRetireDate}}</text>
      </view>
      <view class="param-row">
        <text class="param-label">退休年龄</text>
        <text class="param-value">{{legalAge}}</text>
      </view>
      <view class="param-row">
        <text class="param-label">缴费年限</text>
        <text class="param-value">{{legalTotalYears}}</text>
      </view>
      <view class="param-row">
        <text class="param-label">替代率</text>
        <text class="param-value">{{legalRate}}%</text>
      </view>
    </view>

    <!-- 弹性提前退休对比 -->
    <view class="card" wx:if="{{canFlex}}">
      <text class="section-title">弹性提前退休对比</text>
      <view class="flex-row">
        <view class="flex-item">
          <text class="flex-label">法定退休</text>
          <text class="flex-date">{{legalDate}}</text>
          <text class="flex-amount">{{legalFlexTotal}}元</text>
        </view>
        <view class="flex-divider">vs</view>
        <view class="flex-item">
          <text class="flex-label">弹性提前</text>
          <text class="flex-date">{{flexDate}}</text>
          <text class="flex-amount">{{flexTotal}}元</text>
        </view>
      </view>
      <view class="flex-note">
        提前 {{flexAdvance}} 个月，每月少领 {{flexDiff}} 元
      </view>
    </view>

    <!-- 导出报告引导 -->
    <view class="card export-card">
      <text class="export-title">获取完整报告</text>
      <text class="export-desc">包含参数明细、退休规划建议、缴费优化方案</text>
      <button class="export-btn" bindtap="exportReport">
        导出详细报告 ¥3
      </button>
    </view>
  </scroll-view>
</view>
