/* pages/retire-age/retire-age.wxss - 退休年龄查询样式 */
.container { min-height: 100vh; background: #f8f9fa; }
.nav-bar {
  display: flex; align-items: center; justify-content: space-between;
  background: #1e3a5f; color: #fff; padding: 20rpx 24rpx;
}
.back-btn { font-size: 32rpx; width: 120rpx; }
.nav-title { font-size: 34rpx; font-weight: 600; }
.nav-placeholder { width: 120rpx; }
.scroll-area { height: calc(100vh - 88rpx); }

.card {
  background: #fff; border-radius: 16rpx; padding: 28rpx; margin: 20rpx 24rpx;
}
.section-title {
  display: block; font-size: 30rpx; font-weight: 600; color: #111827; margin-bottom: 20rpx;
}
.form-group {
  display: flex; align-items: center; justify-content: space-between;
  padding: 16rpx 0; border-bottom: 1rpx solid #f3f4f6;
}
.label { font-size: 28rpx; color: #374151; }
.radio-label { margin-right: 24rpx; font-size: 28rpx; color: #374151; }
.picker-value { font-size: 28rpx; color: #2563eb; }

.submit-section { padding: 20rpx 24rpx; }
.submit-btn {
  background: #2563eb; color: #fff; border-radius: 12rpx; font-size: 32rpx; padding: 20rpx 0;
}

.result-card { background: #f0f9ff; }
.result-row {
  display: flex; justify-content: space-between; align-items: center;
  padding: 16rpx 0; border-bottom: 1rpx solid #e0f2fe;
}
.result-row.highlight { background: #dbeafe; margin: 0 -28rpx; padding: 20rpx 28rpx; }
.result-label { font-size: 26rpx; color: #0369a1; }
.result-value { font-size: 26rpx; color: #0c4a6e; font-weight: 600; }
.result-value.big { font-size: 36rpx; color: #1d4ed; }

.divider { height: 1rpx; background: #bfdbfe; margin: 12rpx 0; }

.footer { text-align: center; padding: 30rpx 24rpx 60rpx; }
.footer-text { display: block; font-size: 22rpx; color: #9ca3af; line-height: 1.6; }
