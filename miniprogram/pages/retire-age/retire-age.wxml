<!--pages/retire-age/retire-age.wxml - 退休年龄查询结果页-->
<view class="container">
  <view class="nav-bar">
    <text class="back-btn" bindtap="goBack">‹ 返回</text>
    <text class="nav-title">退休年龄查询</text>
    <view class="nav-placeholder"></view>
  </view>

  <scroll-view scroll-y class="scroll-area">
    <!-- 输入区域 -->
    <view class="card">
      <text class="section-title">查询条件</text>
      
      <view class="form-group">
        <text class="label">性别</text>
        <radio-group bindchange="onGenderChange">
          <label class="radio-label"><radio value="male" checked="{{gender === 'male'}}" /> 男</label>
          <label class="radio-label"><radio value="female" checked="{{gender === 'female'}}" /> 女（50岁退休）</label>
        </radio-group>
      </view>

      <view class="form-group">
        <text class="label">出生年月</text>
        <picker mode="date" fields="month" bindchange="onBirthChange" value="{{birthDate}}">
          <view class="picker-value">{{birthDate || '请选择出生年月'}}</view>
        </picker>
      </view>
    </view>

    <!-- 查询按钮 -->
    <view class="submit-section">
      <button class="submit-btn" bindtap="onQuery" loading="{{loading}}" disabled="{{loading}}">
        查询退休年龄
      </button>
    </view>

    <!-- 结果展示 -->
    <view wx:if="{{result}}" class="card result-card">
      <text class="section-title">查询结果</text>
      
      <view class="result-row highlight">
        <text class="result-label">延迟后退休年龄</text>
        <text class="result-value big">{{result.newAge}}</text>
      </view>
      <view class="result-row">
        <text class="result-label">延迟后退休日期</text>
        <text class="result-value">{{result.retireDate}}</text>
      </view>

      <view class="divider"></view>

      <view class="result-row">
        <text class="result-label">原法定退休年龄</text>
        <text class="result-value">{{result.originalAge}}</text>
      </view>
      <view class="result-row">
        <text class="result-label">原退休日期</text>
        <text class="result-value">{{result.originalDate}}</text>
      </view>
      <view class="result-row">
        <text class="result-label">延迟月数</text>
        <text class="result-value">{{result.delayMonths}}</text>
      </view>
    </view>

    <view class="footer">
      <text class="footer-text">依据：国办发〔2025〕5号《关于实施渐进式延迟法定退休年龄的决定》</text>
      <text class="footer-text">查询结果仅供参考，以社保部门核定为准</text>
    </view>
  </scroll-view>
</view>
