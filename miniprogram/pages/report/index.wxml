<!--pages/report/index.wxml-->
<view class="container">

  <!-- ═ 报告头部 ║ -->
  <view class="rpt-header">
    <text class="rpt-title">养老金测算报告</text>
    <text class="rpt-sub">现实调音师 · 吉林省社保政策解读</text>
    <text class="rpt-date">报告生成时间：{{reportDate}}</text>
  </view>

  <!-- ═ 一、人员信息 ║ -->
  <view class="section">
    <text class="section-title">一、人员信息</text>
    <view class="info-grid">
      <view class="info-row"><text class="info-label">人员类别</text><text class="info-value">{{personTypeLabel}}</text></view>
      <view class="info-row"><text class="info-label">参保地区</text><text class="info-value">{{cityLabel}}</text></view>
      <view class="info-row"><text class="info-label">出生年月</text><text class="info-value">{{birthDate}}</text></view>
      <view class="info-row"><text class="info-label">参工时间</text><text class="info-value">{{workDate}}</text></view>
      <view class="info-row"><text class="info-label">法定退休时间</text><text class="info-value">{{retireDate}}</text></view>
      <view class="info-row"><text class="info-label">法定退休年龄</text><text class="info-value">{{retireAge}}</text></view>
      <view class="info-row" wx:if="{{showFlex}}"><text class="info-label">弹性提前退休时间</text><text class="info-value">{{flexDate}}</text></view>
      <view class="info-row" wx:if="{{showFlex}}"><text class="info-label">弹性提前退休年龄</text><text class="info-value">{{flexAge}}</text></view>
    </view>
  </view>

  <!-- ═ 二、缴费信息 ║ -->
  <view class="section">
    <text class="section-title">二、缴费信息</text>
    <view class="info-grid">
      <view class="info-row"><text class="info-label">累计缴费年限</text><text class="info-value">{{totalYearsText}}</text></view>
      <view class="info-row"><text class="info-label">平均缴费指数</text><text class="info-value {{avgIndexClass}}">{{avgIndexText}}</text></view>
      <view class="info-row"><text class="info-label">个人账户储存额</text><text class="info-value">{{personalAccText}}</text></view>
    </view>
  </view>

  <!-- ═ 三、法定退休养老金计算 ║ -->
  <view class="section">
    <text class="section-title">三、法定退休养老金计算</text>

    <!-- 基础养老金 -->
    <view class="calc-block">
      <text class="calc-label">① 基础养老金</text>
      <text class="calc-formula">公式：{{basicFormula}}</text>
      <text class="calc-substitute">代入：{{basicSubstitute}}</text>
      <text class="calc-result">计算结果：¥{{basicAmountText}}</text>
    </view>

    <!-- 个人账户养老金 -->
    <view class="calc-block">
      <text class="calc-label">② 个人账户养老金</text>
      <text class="calc-formula">公式：{{personalFormula}}</text>
      <text class="calc-substitute">代入：{{personalSubstitute}} = {{personalAmountText}} ÷ {{personalMonths}}</text>
      <text class="calc-result">计算结果：¥{{personalAmountText}}</text>
    </view>

    <!-- 过渡性养老金 -->
    <view class="calc-block">
      <text class="calc-label">③ 过渡性养老金</text>
      <text class="calc-formula">公式：{{transFormula}}</text>
      <text class="calc-substitute">代入：{{transSubstitute}}</text>
      <text class="calc-result">计算结果：¥{{transAmountText}}</text>
    </view>

    <!-- 增发养老金 -->
    <view class="calc-block" wx:if="{{extraAmountText !== '0.00'}}">
      <text class="calc-label">④ 增发基础养老金</text>
      <text class="calc-formula">说明：{{extraFormula}}</text>
      <text class="calc-result">计算结果：¥{{extraAmountText}}</text>
    </view>

    <!-- 其它加发 -->
    <view class="calc-block" wx:if="{{bonusAmountText !== '0.00'}}">
      <text class="calc-label">⑤ 其它加发</text>
      <text class="calc-formula">说明：{{bonusDesc}}</text>
      <text class="calc-result">计算结果：¥{{bonusAmountText}}</text>
    </view>

    <!-- 合计 -->
    <view class="calc-total">
      <text class="total-label">每月基本养老金合计</text>
      <text class="total-value">¥{{legalTotalText}}</text>
    </view>
  </view>

  <!-- ═ 四、弹性提前退休对比 ║ -->
  <view class="section" wx:if="{{showFlex}}">
    <text class="section-title">四、弹性提前退休测算对比</text>
    <view class="flex-note">以下按弹性提前退休（最多提前36个月）测算，供参考：</view>

    <view class="calc-block">
      <text class="calc-label">① 基础养老金（弹性）</text>
      <text class="calc-formula">公式：{{flexBasicFormula}}</text>
      <text class="calc-substitute">代入：{{flexBasicSubstitute}}</text>
      <text class="calc-result">计算结果：¥{{flexBasicAmountText}}</text>
    </view>

    <view class="calc-block">
      <text class="calc-label">② 个人账户养老金（弹性）</text>
      <text class="calc-formula">公式：{{flexPersonalFormula}}</text>
      <text class="calc-substitute">代入：{{flexPersonalSubstitute}}</text>
      <text class="calc-result">计算结果：¥{{flexPersonalAmountText}}</text>
    </view>

    <view class="calc-block">
      <text class="calc-label">③ 过渡性养老金（弹性）</text>
      <text class="calc-formula">公式：{{flexTransFormula}}</text>
      <text class="calc-substitute">代入：{{flexTransSubstitute}}</text>
      <text class="calc-result">计算结果：¥{{flexTransAmountText}}</text>
    </view>

    <!-- 弹性合计 -->
    <view class="calc-total flex-total">
      <text class="total-label">弹性提前退休每月养老金</text>
      <text class="total-value">¥{{flexTotalAmountText}}</text>
    </view>

    <view class="flex-compare">
      <text class="compare-label">弹性 vs 法定差额</text>
      <text class="compare-value">¥{{flexTotalAmountText}} − ¥{{legalTotalText}} = ¥{{diffText}}</text>
    </view>
  </view>

  <!-- ═ 五、历年缴费明细 ║ -->
  <view class="section">
    <text class="section-title">五、历年缴费明细</text>
    <view class="year-table">
      <view class="year-thead">
        <text class="year-th">年份</text>
        <text class="year-th">缴费基数</text>
        <text class="year-th">社平工资</text>
        <text class="year-th">指数</text>
      </view>
      <scroll-view scroll-y class="year-tbody">
        <view class="year-tr" wx:for="{{yearDetailList}}" wx:key="year">
          <text class="year-td">{{item.year}}</text>
          <text class="year-td">{{item.baseText}}</text>
          <text class="year-td">{{item.avgWageText}}</text>
          <text class="year-td {{item.indexClass}}">{{item.indexText}}</text>
        </view>
      </scroll-view>
    </view>
  </view>

  <!-- ═ 六、重要说明 ║ -->
  <view class="section">
    <text class="section-title">六、重要说明</text>
    <view class="policy-list">
      <view class="policy-item">
        <text class="policy-text">基础养老金计发基数：退休地计发基数与全省计发基数取均值参与计算。</text>
      </view>
      <view class="policy-item">
        <text class="policy-text">长春市计发基数与全省计发基数预计于2030年左右趋于一致，此后全省统一使用一个计发基数。</text>
      </view>
      <view class="policy-item">
        <text class="policy-text">预测规则：2026-2030年长春市基数年均增长约2.6%，全省其他地区年均增长约4.38%；2031年起全省统一基数，按年均2.6%增长。</text>
      </view>
      <view class="policy-item">
        <text class="policy-text">个人账户记账利率：2016年前由各省自行制定，2016年起执行全国统一记账利率（详见engine/pension-engine.js头部NATIONAL_INTEREST_RATES表）。</text>
      </view>
    </view>
  </view>

  <!-- ═ 七、免责条款 ║ -->
  <view class="section disclaimer">
    <text class="section-title">七、免责条款</text>
    <view class="disclaimer-list">
      <view class="disclaimer-item">
        <text class="disclaimer-text">本报告基于当前有效政策及公开数据测算，实际养老金待遇以社保局最终核定为准。</text>
      </view>
      <view class="disclaimer-item">
        <text class="disclaimer-text">计发基数采用预测值的，结果仅供参考，待官方公布后需重新测算。</text>
      </view>
      <view class="disclaimer-item">
        <text class="disclaimer-text">本报告生成时间：{{reportDate}}</text>
      </view>
      <view class="disclaimer-item">
        <text class="disclaimer-text">{{dataVersion}}</text>
      </view>
    </view>
  </view>

  <!-- 底部行动区 -->
  <view class="report-actions">
    <button class="btn-primary btn-lg" bindtap="onPayReport">支付 ¥0.99 查看完整报告</button>
    <view class="action-row">
      <button class="btn-ghost" bindtap="onShareReport">分享报告</button>
      <button class="btn-ghost" bindtap="onCustomConsult">定制咨询 ¥19.9</button>
    </view>
  </view>

  <view class="report-footer">
    <text class="footer-text">本报告由「现实调音师」养老金计算平台生成</text>
    <text class="footer-text">咨询微信：现实调音师</text>
  </view>

</view>
