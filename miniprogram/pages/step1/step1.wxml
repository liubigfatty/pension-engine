<!--pages/step1/step1.wxml - 修复版（地区选择器常显示）-->
<view class="step-container">
  <!-- 进度条 -->
  <view class="progress-bar">
    <view class="progress-step active">
      <view class="step-dot">1</view>
      <text class="step-label">选择地区</text>
    </view>
    <view class="step-line"></view>
    <view class="progress-step">
      <view class="step-dot">2</view>
      <text class="step-label">个人信息</text>
    </view>
    <view class="step-line"></view>
    <view class="progress-step">
      <view class="step-dot">3</view>
      <text class="step-label">缴费信息</text>
    </view>
  </view>

  <!-- 标题 -->
  <text class="page-title">选择参保地区</text>
  <text class="page-desc">不同地区的计发基数不同，请准确选择</text>

  <!-- 省份选择 -->
  <view class="form-group">
    <text class="form-label"><text class="form-required">*</text> 参保省份</text>
    <picker mode="selector" range="{{provinceNames}}" value="{{provinceIndex}}" bindchange="onProvinceChange">
      <view class="picker-box {{provinceIndex >= 0 ? '' : 'placeholder'}}">
        {{provinceIndex >= 0 ? provinceNames[provinceIndex] : '请选择省份'}}
        <text class="picker-arrow">›</text>
      </view>
    </picker>
  </view>

  <!-- 地区选择（常显示） -->
  <view class="form-group">
    <text class="form-label"><text class="form-required">*</text> {{cityTypeNames.length > 1 ? '基数类型' : '地区'}}</text>
    <!-- 多基数省份：可以选择 -->
    <picker mode="selector" range="{{cityTypeNames}}" value="{{cityTypeIndex}}" bindchange="onCityTypeChange" wx:if="{{provinceIndex >= 0 && cityTypeNames.length > 1}}">
      <view class="picker-box">
        {{cityTypeNames[cityTypeIndex]}}
        <text class="picker-arrow">›</text>
      </view>
    </picker>
    <!-- 单基数省份：显示唯一选项（不可更改） -->
    <view class="picker-box disabled" wx:if="{{provinceIndex >= 0 && cityTypeNames.length === 1}}">
      {{cityTypeNames[0]}}
    </view>
    <!-- 未选择省份：提示先选择省份 -->
    <view class="picker-box placeholder" wx:if="{{provinceIndex < 0}}">
      请先选择省份
    </view>
  </view>

  <!-- 提示信息 -->
  <view class="tip-box" wx:if="{{provinceIndex >= 0}}">
    <text class="tip-icon">💡</text>
    <view class="tip-content">
      <text class="tip-text">已选择：{{provinceNames[provinceIndex]}} · {{cityTypeNames[cityTypeIndex] || cityTypeNames[0]}}</text>
    </view>
  </view>

  <!-- 下一步按钮（使用.btn-next样式：绿色填充） -->
  <view class="btn-area">
    <button class="btn-next" bindtap="onNext">下一步</button>
  </view>
</view>
