<!--pages/step1/step1.wxml-->
<view class="container">
  <!-- 进度指示 -->
  <view class="progress">
    <view class="progress-dot active"></view>
    <view class="progress-line active"></view>
    <view class="progress-dot"></view>
    <view class="progress-line"></view>
    <view class="progress-dot"></view>
  </view>
  <text class="page-title">选择参保地区</text>
  <text class="page-desc">不同地区计发基数和政策有所不同</text>

  <!-- 省份选择 -->
  <view class="form-group">
    <view class="form-label">参保省份 <text class="required">*</text></view>
    <picker mode="selector" range="{{provinceNames}}" value="{{provinceIndex}}" bindchange="onProvinceChange" disabled="{{provinceNames.length === 0}}">
      <view class="picker-value {{provinceIndex >= 0 ? 'selected' : 'placeholder'}}">
        {{provinceIndex >= 0 ? provinceNames[provinceIndex] : '请选择省份'}}
        <text class="picker-arrow">›</text>
      </view>
    </picker>
  </view>

  <!-- 城市/基数类型选择（选中省份后显示） -->
  <view class="form-group" wx:if="{{cityTypeNames.length > 0}}">
    <view class="form-label">{{cityTypeNames.length > 1 ? '基数类型' : '地区'}} <text class="required">*</text></view>
    <picker mode="selector" range="{{cityTypeNames}}" value="{{cityTypeIndex}}" bindchange="onCityTypeChange" wx:if="{{cityTypeNames.length > 1}}">
      <view class="picker-value selected">
        {{cityTypeNames[cityTypeIndex]}}
        <text class="picker-arrow">›</text>
      </view>
    </picker>
    <view class="info-box" wx:else>
      <text class="info-text">{{cityTypeNames[0]}}</text>
      <text class="info-sub">该省采用统一计发基数</text>
    </view>
  </view>

  <!-- 提示信息 -->
  <view class="tip-box" wx:if="{{provinceIndex >= 0}}">
    <text class="tip-icon">💡</text>
    <text class="tip-text">已选择：{{provinceNames[provinceIndex]}} · {{cityTypeLabels[cityTypeIndex] || cityTypeNames[cityTypeIndex] || '全省统一'}}</text>
  </view>

  <!-- 按钮 -->
  <view class="btn-area">
    <button class="btn-next" bindtap="onNext">下一步</button>
  </view>
</view>
