/* pages/step1/step1.wxss - 使用全局设计系统 v2.0 */

/* 进度条（使用全局.progress-bar系统，覆盖部分样式） */
.progress-bar {
  margin-bottom: var(--space-xxl);
}

/* 表单（使用全局.form-group和.form-label，无需重复定义） */

/* 选择器（基于全局.picker-box，增加选中状态） */
.picker-value {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-md) var(--space-lg);
  border-radius: var(--radius-round);
  font-size: var(--font-size-base);
  background: var(--color-bg-input);
  border: 2rpx solid transparent;
  transition: all var(--transition-fast);
}

.picker-value.selected {
  color: var(--color-text-primary);
  background: var(--color-bg-card);
  border-color: var(--color-primary);
  box-shadow: 0 2rpx 12rpx rgba(7,193,96,0.08);
}

.picker-value.placeholder {
  color: var(--color-text-hint);
}

.picker-arrow {
  font-size: var(--font-size-md);
  color: var(--color-text-hint);
}

/* 信息框（单基数省份） */
.info-box {
  padding: var(--space-md);
  border-radius: var(--radius-md);
  background: #f0faf5;
  border: 2rpx solid #d4edda;
}

.info-text {
  font-size: var(--font-size-base);
  color: #155724;
  font-weight: var(--font-weight-medium);
  display: block;
}

.info-sub {
  font-size: var(--font-size-sm);
  color: #6c9b78;
  display: block;
  margin-top: var(--space-xs);
}

/* 提示框（使用全局.tip-box，覆盖部分样式） */
.tip-box {
  margin-bottom: var(--space-xxl);
}

.tip-icon { 
  font-size: var(--font-size-md); 
  margin-right: var(--space-sm); 
  flex-shrink: 0; 
}

.tip-content {
  display: flex;
  flex-direction: column;
  flex: 1;
}

.tip-text { 
  font-size: var(--font-size-base); 
  color: var(--color-info); 
  font-weight: var(--font-weight-medium); 
  line-height: var(--line-height-tight); 
}

.tip-sub { 
  font-size: var(--font-size-sm); 
  color: var(--color-text-hint); 
  margin-top: var(--space-xs); 
  line-height: var(--line-height-tight); 
}

/* 按钮区域（使用全局.btn-area，覆盖部分样式） */
.btn-area { 
  margin-top: var(--space-md); 
}

.btn-next {
  width: 100%;
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
  color: var(--color-text-white);
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-medium);
  border: none;
  border-radius: var(--radius-round);
  padding: var(--space-md) 0;
  letter-spacing: 4rpx;
}

.btn-next::after { 
  border: none; 
}
