/* pages/step1/step1.wxss - 布局优化版 */

.container {
  min-height: 100vh;
  background: #F5F3F0;
  padding: 24rpx 28rpx 60rpx;
  box-sizing: border-box;
}

/* ══════════════════════════════
   步骤指示 - 更紧凑
   ══════════════════════════════ */
.step-indicator {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 0 28rpx;
}

.step-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.step-dot {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #D5CEC3;
  color: #AAAAAA;
  font-size: 22rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.step-item.active .step-dot {
  background: #8B7355;
  color: #FFFFFF;
}

.step-name {
  font-size: 24rpx;
  color: #AAAAAA;
}

.step-item.active .step-name {
  color: #8B7355;
  font-weight: 500;
}

.step-line {
  width: 60rpx;
  height: 3rpx;
  background: #D5CEC3;
  margin: 0 16rpx;
  margin-bottom: 2rpx;
}

/* ══════════════════════════════
   表单卡片 - 更紧凑
   ══════════════════════════════ */
.form-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 36rpx 32rpx 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

/* ══════════════════════════════
   表单项 - 标签+输入框
   ══════════════════════════════ */
.form-item {
  margin-bottom: 28rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

/* 标签行：标签名 + 必填星号 */
.form-label-row {
  display: flex;
  align-items: center;
  gap: 6rpx;
  margin-bottom: 10rpx;
}

.form-label {
  font-size: 27rpx;
  color: #555555;
  font-weight: 500;
}

.form-required {
  color: #C0392B;
  font-size: 24rpx;
}

/* ══════════════════════════════
   选择器/输入框 - 统一样式
   ══════════════════════════════ */
.picker-box {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  background: #FAFAFA;
  border: 2rpx solid #E5E5EA;
  border-radius: 14rpx;
  font-size: 29rpx;
  color: #28292B;
  transition: all 0.2s ease;
}

.picker-box.selected {
  border-color: #8B7355;
  background: #FFFFFF;
}

.picker-box.placeholder text,
.picker-box .placeholder {
  color: #BBBBBB;
}

.picker-arrow {
  font-size: 18rpx;
  color: #CCCCCC;
  margin-left: 12rpx;
  flex-shrink: 0;
}

/* ══════════════════════════════
   单选按钮组
   ══════════════════════════════ */
.radio-group {
  display: flex;
  gap: 20rpx;
}

.radio-btn {
  flex: 1;
  text-align: center;
  padding: 22rpx 0;
  background: #FAFAFA;
  border: 2rpx solid #E5E5EA;
  border-radius: 14rpx;
  font-size: 27rpx;
  color: #555555;
  transition: all 0.2s ease;
}

.radio-btn.active {
  background: linear-gradient(135deg, #8B7355, #A08566);
  color: #FFFFFF;
  border-color: transparent;
  box-shadow: 0 4rpx 14rpx rgba(139,115,85,0.25);
}

/* ══════════════════════════════
   下一步按钮
   ══════════════════════════════ */
.btn-wrap {
  margin-top: 40rpx;
}

.btn-primary {
  width: 100%;
  background: linear-gradient(135deg, #8B7355 0%, #A08566 100%);
  color: #FFFFFF !important;
  border: none !important;
  border-radius: 48rpx !important;
  padding: 26rpx 0;
  font-size: 30rpx !important;
  font-weight: 600 !important;
  letter-spacing: 4rpx;
  box-shadow: 0 6rpx 20rpx rgba(139,115,85,0.3);
  line-height: normal;
}

.btn-primary::after {
  border: none !important;
}
