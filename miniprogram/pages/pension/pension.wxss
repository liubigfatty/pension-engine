/* pages/pension/pension.wxss */
/* 与 WorkBuddy 项目 pages/pension/index.wxss 保持同步 */
/* 最后同步：2026-05-21 */

/* ===== 全局 ===== */
.container {
  min-height: 100vh;
  background: #f0f4f8;
  padding: 24rpx 24rpx 60rpx;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
}

/* ===== 步骤面板 ===== */
.step-panel {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 36rpx 32rpx 40rpx;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.08);
  margin-bottom: 24rpx;
}
.panel-header {
  display: flex;
  align-items: center;
  margin-bottom: 36rpx;
}
.panel-step {
  width: 48rpx;
  height: 48rpx;
  background: linear-gradient(135deg, #1e3a5f, #2563eb);
  color: #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  margin-right: 16rpx;
  flex-shrink: 0;
}
.panel-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1e293b;
}

/* ===== 字段块 ===== */
.field-block {
  margin-bottom: 28rpx;
}
.field-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #374151;
  margin-bottom: 12rpx;
  display: flex;
  align-items: center;
}
.field-tag-optional {
  font-size: 22rpx;
  color: #9ca3af;
  margin-left: 8rpx;
  font-weight: 400;
}
.field-hint {
  font-size: 22rpx;
  color: #f59e0b;
  background: #fffbeb;
  padding: 12rpx 16rpx;
  border-radius: 10rpx;
  margin-bottom: 20rpx;
  line-height: 1.6;
}
.field-row {
  display: flex;
  gap: 16rpx;
}
.picker-box {
  flex: 1;
  background: #f8fafc;
  border: 2rpx solid #e2e8f0;
  border-radius: 14rpx;
  padding: 20rpx 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 28rpx;
  color: #94a3b8;
  transition: all 0.2s;
}
.picker-box.filled {
  color: #1e293b;
  border-color: #3b82f6;
  background: #eff6ff;
}
.picker-arrow {
  font-size: 20rpx;
  color: #94a3b8;
  flex-shrink: 0;
}

/* ===== 按钮 ===== */
.action-row {
  margin-top: 40rpx;
  display: flex;
  gap: 20rpx;
}
.btn-primary {
  flex: 1;
  background: linear-gradient(135deg, #1e3a5f 0%, #2563eb 100%);
  color: #ffffff;
  border: none;
  border-radius: 16rpx;
  padding: 0;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  box-shadow: 0 4rpx 16rpx rgba(37,99,235,0.3);
}
.btn-primary::after { border: none; }
.btn-ghost {
  flex: 1;
  background: #f1f5f9;
  color: #475569;
  border: 2rpx solid #e2e8f0;
  border-radius: 16rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 28rpx;
}
.btn-ghost::after { border: none; }
.btn-lg {
  width: 100%;
}

/* ===== Step 2 模式面板（上下排列） ===== */
.mode-panel {
  margin-bottom: 28rpx;
  background: #f8fafc;
  border-radius: 14rpx;
  padding: 24rpx;
}
.mode-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1e293b;
  margin-bottom: 16rpx;
  display: block;
}

/* ===== 导入数据 ===== */
.btn-excel {
  width: 100%;
  background: #eff6ff;
  color: #1d4ed;
  border: 2rpx dashed #93c5fd;
  border-radius: 14rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 28rpx;
  font-weight: 500;
}
.btn-excel::after { border: none; }
.excel-hint {
  display: block;
  font-size: 22rpx;
  color: #94a3b8;
  text-align: center;
  margin-top: 12rpx;
}
.import-ok {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 20rpx;
  font-size: 24rpx;
  color: #059669;
  background: #ecfdf5;
  padding: 12rpx 16rpx;
  border-radius: 10rpx;
}
.import-ok-icon {
  font-size: 28rpx;
  font-weight: 700;
}

/* ===== 手动输入 ===== */
.manual-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}
.manual-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1e293b;
}

/* ===== 年份表格 ===== */
.year-table {
  background: #ffffff;
  border-radius: 14rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  border: 2rpx solid #e2e8f0;
}
.year-thead {
  display: flex;
  background: #e2e8f0;
  padding: 14rpx 16rpx;
  font-size: 22rpx;
  color: #475569;
  font-weight: 600;
}
.year-th {
  flex: 1;
  text-align: center;
}
.year-tbody {
  max-height: 480rpx;
}
.year-tr {
  display: flex;
  padding: 16rpx;
  border-bottom: 1rpx solid #f1f5f9;
  align-items: center;
}
.year-td {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  color: #1e293b;
}
.year-input {
  flex: 1;
  background: #f8fafc;
  border: 2rpx solid #e2e8f0;
  border-radius: 8rpx;
  padding: 8rpx 12rpx;
  font-size: 24rpx;
  text-align: center;
}
.year-tfoot {
  display: flex;
  padding: 16rpx;
  background: #eff6ff;
  font-weight: 600;
}
.year-tf {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  color: #1d4ed;
}

/* ===== 指数颜色 ===== */
.index-low { color: #ef4444; font-weight: 600; }
.index-mid { color: #3b82f6; }
.index-high { color: #059669; font-weight: 600; }

/* ===== 档位输入 ===== */
.tier-section {
  background: #ffffff;
  border-radius: 14rpx;
  padding: 24rpx;
  margin-top: 24rpx;
  border: 2rpx solid #e2e8f0;
}
.tier-label {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #374151;
  margin-bottom: 8rpx;
}
.tier-hint {
  display: block;
  font-size: 22rpx;
  color: #94a3b8;
  margin-bottom: 16rpx;
}
.tier-input-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.tier-input {
  flex: 1;
  background: #f8fafc;
  border: 2rpx solid #e2e8f0;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
}
.tier-unit {
  font-size: 28rpx;
  color: #64748b;
  font-weight: 600;
}

/* ===== Step 3 结果卡片 ===== */
.result-cards {
  display: flex;
  gap: 16rpx;
  margin-bottom: 32rpx;
}
.result-card {
  flex: 1;
  background: #f8fafc;
  border-radius: 16rpx;
  padding: 20rpx 16rpx;
  text-align: center;
}
.result-card-label {
  display: block;
  font-size: 22rpx;
  color: #64748b;
  margin-bottom: 8rpx;
}
.result-card-value {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #1e3a5f;
}

/* ===== 历年明细 ===== */
.detail-section {
  margin-bottom: 32rpx;
}
.detail-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #1e293b;
  margin-bottom: 16rpx;
}
.detail-table {
  background: #ffffff;
  border-radius: 14rpx;
  overflow: hidden;
  border: 2rpx solid #e2e8f0;
}
.detail-thead {
  display: flex;
  background: linear-gradient(135deg, #1e3a5f, #2563eb);
  padding: 16rpx 12rpx;
}
.detail-th {
  flex: 1;
  text-align: center;
  font-size: 22rpx;
  color: #ffffff;
  font-weight: 600;
}
.detail-tbody { }
.detail-tr {
  display: flex;
  padding: 14rpx 12rpx;
  border-bottom: 1rpx solid #f1f5f9;
}
.detail-tr:nth-child(even) {
  background: #f8fafc;
}
.detail-td {
  flex: 1;
  text-align: center;
  font-size: 22rpx;
  color: #374151;
}

/* ===== Step 4 Hero ===== */
.pension-hero {
  background: linear-gradient(135deg, #1e3a5f 0%, #1e40af 60%, #3730a3 100%);
  border-radius: 24rpx;
  padding: 48rpx 32rpx;
  text-align: center;
  margin-bottom: 32rpx;
  color: #ffffff;
}
.pension-hero-label {
  display: block;
  font-size: 26rpx;
  color: #bfdbfe;
  margin-bottom: 12rpx;
}
.pension-hero-value {
  display: block;
  font-size: 72rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
  line-height: 1.1;
}
.pension-hero-note {
  display: block;
  font-size: 22rpx;
  color: #93c5fd;
  margin-top: 16rpx;
  opacity: 0.8;
}

/* ===== 分项明细 ===== */
.breakdown-section {
  margin-bottom: 32rpx;
}
.breakdown-item {
  background: #ffffff;
  border-radius: 14rpx;
  margin-bottom: 12rpx;
  overflow: hidden;
  border: 2rpx solid #e2e8f0;
}
.breakdown-header {
  display: flex;
  align-items: center;
  padding: 24rpx;
  gap: 12rpx;
}
.breakdown-label {
  flex: 1;
  font-size: 26rpx;
  font-weight: 600;
  color: #1e293b;
}
.breakdown-value {
  font-size: 30rpx;
  font-weight: 700;
  color: #1e3a5f;
}
.breakdown-arrow {
  font-size: 20rpx;
  color: #94a3b8;
}
.breakdown-formula {
  padding: 16rpx 24rpx;
  font-size: 22rpx;
  color: #64748b;
  background: #f8fafc;
  border-top: 1rpx solid #e2e8f0;
}

/* ===== 对比区域（重构） ===== */
.compare-section {
  margin-bottom: 32rpx;
}
.compare-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #1e293b;
  margin-bottom: 20rpx;
}
.compare-detail {
  background: #f8fafc;
  border-radius: 14rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 20rpx;
}
.compare-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10rpx 0;
  border-bottom: 1rpx solid #e2e8f0;
}
.compare-row:last-child {
  border-bottom: none;
}
.compare-label {
  font-size: 24rpx;
  color: #475569;
}
.compare-value {
  font-size: 26rpx;
  font-weight: 600;
  color: #1e293b;
}
.compare-diff {
  color: #ef4444;
}

/* 对比条形图 */
.compare-section {
  margin-bottom: 32rpx;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  border: 2rpx solid #e2e8f0;
}
.compare-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #1e293b;
  margin-bottom: 20rpx;
}
.compare-detail {
  background: #f8fafc;
  border-radius: 14rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 24rpx;
}
.compare-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10rpx 0;
  border-bottom: 1rpx solid #e2e8f0;
}
.compare-row:last-child {
  border-bottom: none;
}
.compare-label {
  font-size: 24rpx;
  color: #475569;
}
.compare-value {
  font-size: 26rpx;
  font-weight: 600;
  color: #1e293b;
}
.compare-diff {
  color: #ef4444;
}

/* 条形图行 */
.compare-bar-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}
.compare-bar-label {
  font-size: 22rpx;
  color: #475569;
  width: 100rpx;
  flex-shrink: 0;
  text-align: right;
}
.compare-bar-track {
  flex: 1;
  height: 32rpx;
  background: #f1f5f9;
  border-radius: 16rpx;
  overflow: hidden;
  position: relative;
  box-shadow: inset 0 2rpx 8rpx rgba(0,0,0,0.06);
}
.compare-bar-fill {
  height: 100%;
  border-radius: 16rpx;
  transition: width 0.8s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  padding-right: 12rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.15);
}
.compare-bar-normal {
  background: linear-gradient(90deg, #3b82f6, #1d4ed, #2563eb);
}
.compare-bar-early {
  background: linear-gradient(90deg, #f59e0b, #f97316, #ea580c);
}
.compare-bar-num {
  font-size: 20rpx;
  font-weight: 700;
  color: #ffffff;
  text-shadow: 0 1rpx 4rpx rgba(0,0,0,0.3);
  white-space: nowrap;
}
.compare-bar-value {
  font-size: 24rpx;
  font-weight: 600;
  color: #1e293b;
  width: 120rpx;
  text-align: right;
  flex-shrink: 0;
}

/* ===== 行动卡片（加图标） ===== */
.action-cards {
  margin-bottom: 32rpx;
}
.action-card {
  display: flex;
  align-items: center;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 16rpx;
  border: 2rpx solid #e2e8f0;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.action-card:active {
  background: #f8fafc;
}
.action-card-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}
.action-card-left {
  flex: 1;
}
.action-card-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #1e293b;
}
.action-card-desc {
  display: block;
  font-size: 22rpx;
  color: #94a3b8;
  margin-top: 6rpx;
}
.action-card-arrow {
  font-size: 32rpx;
  color: #3b82f6;
  flex-shrink: 0;
  margin-left: 12rpx;
}

/* ===== Footer ===== */
.footer {
  text-align: center;
  font-size: 22rpx;
  color: #94a3b8;
  padding: 32rpx 0 48rpx;
}
