/* pension.wxss - 养老金测算页 */
.container {
  background: #f8f9fa;
  min-height: 100vh;
  padding-bottom: 120rpx;
}

.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  background: #1e3a5f;
  color: #fff;
}

.back-btn {
  font-size: 32rpx;
  color: #fff;
  cursor: pointer;
}

.nav-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}

.nav-placeholder {
  width: 120rpx;
}

.scroll-area {
  padding: 24rpx;
}

.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.06);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1e3a5f;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #e5e7eb;
  display: block;
}

.form-group {
  margin-bottom: 28rpx;
}

.label {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #374151;
  margin-bottom: 12rpx;
}

.input {
  width: 100%;
  padding: 16rpx 24rpx;
  border: 2rpx solid #d1d5db;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #111827;
  background: #fff;
}

.input:focus {
  border-color: #2563eb;
}

.picker-value {
  padding: 16rpx 24rpx;
  border: 2rpx solid #d1d5db;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #111827;
  background: #fff;
}

.radio-label {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 28rpx;
  color: #374151;
}

.submit-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  background: #fff;
  box-shadow: 0 -4rpx 12rpx rgba(0,0,0,0.08);
  z-index: 100;
}

.submit-btn {
  width: 100%;
  padding: 24rpx 0;
  background: #2563eb;
  color: #fff;
  border: none;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 500;
}

.submit-btn:disabled {
  background: #9ca3af;
}

.footer {
  text-align: center;
  padding: 32rpx 0;
}

.footer-text {
  font-size: 22rpx;
  color: #9ca3af;
}
