<!--pension.wxml - 基本信息填报页-->
<view class="container">
  <!-- 返回按钮 -->
  <view class="nav-bar">
    <text class="back-btn" bindtap="goBack">‹ 返回</text>
    <text class="nav-title">基本信息</text>
    <view class="nav-placeholder"></view>
  </view>

  <scroll-view scroll-y class="scroll-area">
    <!-- 参保地区 -->
    <view class="card">
      <text class="section-title">参保信息</text>
      
      <view class="form-group">
        <text class="label">参保地区</text>
        <picker bindchange="onProvinceChange" value="{{provinceIndex}}" range="{{provinceList}}">
          <view class="picker-value">
            {{selectedProvince ? selectedProvince.name : '请选择参保地区'}}
          </view>
        </picker>
      </view>

      <view class="form-group">
        <text class="label">退休地</text>
        <picker bindchange="onCityChange" value="{{cityIndex}}" range="{{cityList}}">
          <view class="picker-value">
            {{selectedCity ? selectedCity.name : '自动识别（默认全省）'}}
          </view>
        </picker>
      </view>
    </view>

    <!-- 人员基本信息 -->
    <view class="card">
      <text class="section-title">人员信息</text>
      
      <view class="form-group">
        <text class="label">姓名</text>
        <input class="input" placeholder="请输入姓名" bindinput="onNameInput" value="{{name}}" />
      </view>

      <view class="form-group">
        <text class="label">性别</text>
        <radio-group bindchange="onGenderChange">
          <label class="radio-label">
            <radio value="male" checked="{{gender === 'male'}}" /> 男
          </label>
          <label class="radio-label">
            <radio value="female" checked="{{gender === 'female'}}" /> 女
          </label>
        </radio-group>
      </view>

      <view class="form-group">
        <text class="label">出生年月</text>
        <picker mode="date" fields="month" bindchange="onBirthChange" value="{{birthDate}}">
          <view class="picker-value">
            {{birthDate || '请选择出生年月'}}
          </view>
        </picker>
      </view>

      <view class="form-group">
        <text class="label">参保类型</text>
        <radio-group bindchange="onTypeChange">
          <label class="radio-label">
            <radio value="standard" checked="{{retireType === 'standard'}}" /> 企业职工
          </label>
          <label class="radio-label">
            <radio value="flexible" checked="{{retireType === 'flexible'}}" /> 灵活就业人员
          </label>
        </radio-group>
      </view>

      <view class="form-group" wx:if="{{gender === 'female'}}">
        <text class="label">退休类型</text>
        <radio-group bindchange="onRetireTypeChange">
          <label class="radio-label">
            <radio value="fc" checked="{{femaleRetireType === 'fc'}}" /> 女干部
          </label>
          <label class="radio-label">
            <radio value="fw" checked="{{femaleRetireType === 'fw'}}" /> 女工人
          </label>
        </radio-group>
      </view>
    </view>

    <!-- 缴费信息 -->
    <view class="card">
      <text class="section-title">缴费信息</text>
      
      <view class="form-group">
        <text class="label">参加工作时间</text>
        <picker mode="date" fields="month" bindchange="onWorkChange" value="{{workDate}}">
          <view class="picker-value">
            {{workDate || '请选择参加工作时间'}}
          </view>
        </picker>
      </view>

      <view class="form-group">
        <text class="label">平均缴费指数</text>
        <input class="input" type="digit" placeholder="如 1.0 表示按100%缴费" bindinput="onIndexInput" value="{{avgIndex}}" />
      </view>

      <view class="form-group" wx:if="{{hasSight}}">
        <text class="label">视同缴费年限（年）</text>
        <input class="input" type="number" placeholder="如无视同缴费请输入0" bindinput="onSightInput" value="{{sightYears}}" />
      </view>

      <view class="form-group">
        <text class="label">个人账户余额（元）</text>
        <input class="input" type="digit" placeholder="可查询社保APP获取，留空自动估算" bindinput="onBalanceInput" value="{{personalAccInput}}" />
      </view>
    </view>

    <!-- 提交按钮 -->
    <view class="submit-section">
      <button class="submit-btn" bindtap="handleSubmit" loading="{{loading}}" disabled="{{loading}}">
        开始测算
      </button>
    </view>

    <!-- 底部说明 -->
    <view class="footer">
      <text class="footer-text">测算结果仅供参考，实际养老金以社保部门核定为准</text>
    </view>
  </scroll-view>
</view>
