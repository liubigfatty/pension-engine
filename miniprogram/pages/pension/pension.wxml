<view class="container">

  <!-- ===== Step 1：基本信息（5个问题同时出现）===== -->
  <view class="step-panel" wx:if="{{currentStep === 1}}">

    <view class="panel-header">
      <view class="panel-step">1</view>
      <text class="panel-title">基本信息</text>
    </view>

    <!-- Q1：缴费地区 -->
    <view class="field-block">
      <view class="field-label">缴费地区</view>
      <view class="field-row">
        <picker bindchange="onProvinceChange" range="{{provinceList}}" value="{{provinceIndex}}">
          <view class="picker-box {{provinceIndex >= 0 ? 'filled' : ''}}">
            <text>{{provinceIndex >= 0 ? provinceList[provinceIndex] : '选择省份'}}</text>
            <text class="picker-arrow">▼</text>
          </view>
        </picker>
        <picker bindchange="onCityChange" range="{{cityList}}" value="{{cityIndex}}">
          <view class="picker-box {{cityIndex >= 0 ? 'filled' : ''}}">
            <text>{{cityIndex >= 0 ? cityList[cityIndex] : '选择城市'}}</text>
            <text class="picker-arrow">▼</text>
          </view>
        </picker>
      </view>
    </view>

    <!-- Q2：人员类型 -->
    <view class="field-block">
      <view class="field-label">人员类型</view>
      <picker bindchange="onPersonTypeChange" range="{{personTypeLabels}}" value="{{personTypeIndex}}">
        <view class="picker-box {{personTypeIndex >= 0 ? 'filled' : ''}}">
          <text>{{personTypeIndex >= 0 ? personTypeLabels[personTypeIndex] : '选择人员类型'}}</text>
          <text class="picker-arrow">▼</text>
        </view>
      </picker>
    </view>

    <!-- Q3：出生年月 -->
    <view class="field-block">
      <view class="field-label">出生年月</view>
      <picker mode="date" fields="month" start="1940-01" end="2010-12" value="{{birthDate}}" bindchange="onBirthDateChange">
        <view class="picker-box {{birthDate ? 'filled' : ''}}">
          <text>{{birthDate || '选择出生年月'}}</text>
          <text class="picker-arrow">▼</text>
        </view>
      </picker>
    </view>

    <!-- Q4：参保时间 -->
    <view class="field-block">
      <view class="field-label">参保时间</view>
      <picker mode="date" fields="month" start="1970-01" end="2030-12" value="{{workDate}}" bindchange="onWorkDateChange">
        <view class="picker-box {{workDate ? 'filled' : ''}}">
          <text>{{workDate || '选择参保时间'}}</text>
          <text class="picker-arrow">▼</text>
        </view>
      </picker>
    </view>

    <!-- Q5：其他加发（选填，改用选择器） -->
    <view class="field-block">
      <view class="field-label">其他加发<text class="field-tag-optional">选填</text></view>
      <view class="field-hint">仅适用于1998年7月1日前获得相应荣誉或职称的人员，该日期之后获得的不再享受退休加发待遇。</view>
      <picker bindchange="onBonusChange" range="{{bonusLabels}}" value="{{bonusIndex}}" range-key="label">
        <view class="picker-box {{bonusIndex >= 0 ? 'filled' : ''}}">
          <text>{{bonusIndex >= 0 ? bonusLabels[bonusIndex] : '选择其他加发情况'}}</text>
          <text class="picker-arrow">▼</text>
        </view>
      </picker>
    </view>

    <!-- 填写缴费信息 -->
    <view class="action-row">
      <button class="btn-primary btn-lg" bindtap="onStartCalc">填写缴费信息</button>
    </view>
  </view>

  <!-- ===== Step 2：缴费信息 ===== -->
  <view class="step-panel" wx:if="{{currentStep === 2}}">

    <view class="panel-header">
      <view class="panel-step">2</view>
      <text class="panel-title">缴费信息</text>
    </view>

    <!-- 模式A：导入数据 -->
    <view class="mode-panel">
      <view class="mode-title">导入缴费数据</view>
      <button class="btn-excel" bindtap="onChooseExcel">📄 从聊天文件导入 Excel</button>
      <text class="excel-hint">支持社保大厅年度对账单Excel文件</text>
      <view class="import-ok" wx:if="{{importSource === 'excel'}}">
        <text class="import-ok-icon">✓</text>
        <text>已导入 {{yearFields.length}} 年数据，可到「手动输入」查看或修改</text>
      </view>
    </view>

    <!-- 模式B：手动输入 -->
    <view class="mode-panel">
      <view class="mode-title">输入缴费基数</view>
      <view class="manual-header">
        <text class="manual-title">历年缴费基数</text>
      </view>
      <view class="year-table" wx:if="{{yearFields.length > 0}}">
        <view class="year-thead">
          <text class="year-th">年份</text>
          <text class="year-th">缴费基数（元）</text>
          <text class="year-th">缴费指数</text>
        </view>
        <scroll-view scroll-y class="year-tbody">
          <view class="year-tr" wx:for="{{yearFields}}" wx:key="year">
            <text class="year-td">{{item.year}}年</text>
            <input class="year-input" type="digit" placeholder="0" value="{{item.base}}" data-idx="{{index}}" bindinput="onYearBaseInput" />
            <text class="year-td {{item.indexClass}}">{{item.indexText}}</text>
          </view>
        </scroll-view>
        <view class="year-tfoot">
          <text class="year-tf">平均指数</text>
          <text class="year-tf"></text>
          <text class="year-tf {{avgIndexClass}}">{{avgIndexText || '--'}}</text>
        </view>
      </view>

      <!-- 或输入档位 -->
      <view class="tier-section">
        <text class="tier-label">或输入档位</text>
        <text class="tier-hint">输入60～300之间任意整数，按此档位估算所有年份</text>
        <view class="tier-input-row">
          <input class="tier-input" type="number" placeholder="60-300" value="{{customTier}}" bindinput="onCustomTierInput" />
          <text class="tier-unit">%</text>
        </view>
      </view>
    </view>

    <!-- 底部按钮 -->
    <view class="action-row">
      <button class="btn-ghost" bindtap="onBackToStep1">返回修改</button>
      <button class="btn-primary" bindtap="onCalculate">开始计算</button>
    </view>
  </view>

  <!-- ===== Step 3：缴费指数计算结果 ===== -->
  <view class="step-panel" wx:if="{{currentStep === 3}}">

    <view class="panel-header">
      <view class="panel-step">3</view>
      <text class="panel-title">缴费指数计算结果</text>
    </view>

    <!-- 核心数字卡片 -->
    <view class="result-cards">
      <view class="result-card">
        <text class="result-card-label">平均缴费指数</text>
        <text class="result-card-value {{avgIndexClass}}">{{avgIndexText || '--'}}</text>
      </view>
      <view class="result-card">
        <text class="result-card-label">个人账户余额</text>
        <text class="result-card-value">{{personalAccText || '--'}}</text>
      </view>
      <view class="result-card">
        <text class="result-card-label">实际缴费年限</text>
        <text class="result-card-value">{{actualYearsText || '--'}}</text>
      </view>
    </view>

    <!-- 历年缴费明细 -->
    <view class="detail-section">
      <text class="detail-title">📋 历年缴费明细</text>
      <view class="detail-table">
        <view class="detail-thead">
          <text class="detail-th">年份</text>
          <text class="detail-th">缴费基数</text>
          <text class="detail-th">社平工资</text>
          <text class="detail-th">缴费指数</text>
          <text class="detail-th">账户余额</text>
        </view>
        <view class="detail-tbody">
          <view class="detail-tr" wx:for="{{yearDetailList}}" wx:key="year">
            <text class="detail-td">{{item.year}}年</text>
            <text class="detail-td">{{item.baseText}}</text>
            <text class="detail-td">{{item.avgWageText}}</text>
            <text class="detail-td {{item.indexClass}}">{{item.indexText}}</text>
            <text class="detail-td">{{item.accText}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 底部按钮 -->
    <view class="action-row">
      <button class="btn-ghost" bindtap="onBackToStep2">返回修改</button>
      <button class="btn-primary" bindtap="onShowPensionResult">养老金测算</button>
    </view>
  </view>

  <!-- ===== Step 4：养老金计算结果 ===== -->
  <view class="step-panel" wx:if="{{currentStep === 4}}">

    <!-- Hero 区 -->
    <view class="pension-hero">
      <text class="pension-hero-label">每月可领取养老金（估算）</text>
      <text class="pension-hero-value">¥{{totalPensionText || '0.00'}}</text>
      <text class="pension-hero-note">基于当前政策测算，实际金额以社保局核定为准</text>
    </view>

    <!-- 分项明细（顺序：基础→个人账户→过渡性→其它加发） -->
    <view class="breakdown-section">
      <view class="breakdown-item" wx:for="{{breakdownList}}" wx:key="label">
        <view class="breakdown-header" bindtap="onToggleBreakdown" data-idx="{{index}}">
          <text class="breakdown-label">{{item.label}}</text>
          <text class="breakdown-value">¥{{item.valueText}}</text>
          <text class="breakdown-arrow">{{item.expanded ? '▲' : '▼'}}</text>
        </view>
        <view class="breakdown-formula" wx:if="{{item.expanded}}">
          <text>{{item.formula}}</text>
        </view>
      </view>
    </view>

    <!-- 法定 vs 弹性对比 -->
    <view class="compare-section">
      <text class="compare-title">法定退休 vs 弹性提前退休</text>
      <view class="compare-detail">
        <view class="compare-row">
          <text class="compare-label">法定退休年龄</text>
          <text class="compare-value">{{normalRetireAge}}岁</text>
        </view>
        <view class="compare-row">
          <text class="compare-label">弹性提前退休年龄</text>
          <text class="compare-value">{{earlyRetireAge}}岁</text>
        </view>
        <view class="compare-row">
          <text class="compare-label">提前月数</text>
          <text class="compare-value">{{earlyMonths}}个月</text>
        </view>
        <view class="compare-row">
          <text class="compare-label">每月差额</text>
          <text class="compare-value compare-diff">¥{{monthlyDiffText}}</text>
        </view>
      </view>
      <view class="compare-bar-row">
        <text class="compare-bar-label">法定退休</text>
        <view class="compare-bar-track">
          <view class="compare-bar-fill compare-bar-normal" style="width:{{normalBarWidth}}%"></view>
        </view>
        <text class="compare-bar-value">¥{{normalPensionText}}</text>
      </view>
      <view class="compare-bar-row">
        <text class="compare-bar-label">弹性提前</text>
        <view class="compare-bar-track">
          <view class="compare-bar-fill compare-bar-early" style="width:{{earlyBarWidth}}%"></view>
        </view>
        <text class="compare-bar-value">¥{{earlyPensionText}}</text>
      </view>
    </view>

    <!-- 底部行动卡片（加图标） -->
    <view class="action-cards">
      <view class="action-card" bindtap="onShareImage">
        <view class="action-card-icon">📤</view>
        <view class="action-card-left">
          <text class="action-card-title">分享结果</text>
          <text class="action-card-desc">¥0.00 · 一键生成养老金结果分享图</text>
        </view>
        <text class="action-card-arrow">▶</text>
      </view>
      <view class="action-card" bindtap="onExportReport">
        <view class="action-card-icon">📊</view>
        <view class="action-card-left">
          <text class="action-card-title">导出报告</text>
          <text class="action-card-desc">¥1.99 · 详细计算报告，含政策依据和测算明细</text>
        </view>
        <text class="action-card-arrow">▶</text>
      </view>
      <view class="action-card" bindtap="onCustomConsult">
        <view class="action-card-icon">💬</view>
        <view class="action-card-left">
          <text class="action-card-title">定制咨询</text>
          <text class="action-card-desc">¥9.90 · 一对一养老金规划定制服务</text>
        </view>
        <text class="action-card-arrow">▶</text>
      </view>
    </view>

    <!-- 底部按钮 -->
    <view class="action-row">
      <button class="btn-ghost" bindtap="onRestart">重新测算</button>
    </view>
  </view>

</view>
