<!--pages/index/index.wxml-->
<view class="container">
  <!-- 隐私协议弹窗（官方规范） -->
  <view class="privacy-mask" wx:if="{{showPrivacy}}">
    <view class="privacy-popup">
      <view class="privacy-title">隐私保护指引</view>
      <view class="privacy-content">
        <text>本小程序需要收集省份、缴费年限、平均指数等信息用于计算养老金。信息仅本地保存，不会上传服务器。\n\n请阅读并同意{{privacyContractName || '《隐私保护指引》'}}。</text>
      </view>
      <view class="privacy-actions">
        <button class="privacy-btn-view" bindtap="onViewPrivacy">查看隐私协议</button>
        <button class="privacy-btn-disagree" bindtap="onDisagreePrivacy">不同意</button>
        <!-- 官方隐私授权按钮 -->
        <button class="privacy-btn-agree" open-type="agreePrivacyAuthorization" bindagreeprivacyauthorization="onAgreePrivacy">同意</button>
      </view>
    </view>
  </view>

  <!-- 主视觉区域 -->
  <view class="hero">
    <image class="logo-img" src="/assets/logo.jpg" mode="aspectFit"></image>
    <view class="hero-overlay">
      <text class="brand-name">正元养老金测算</text>
      <text class="brand-desc">全国31省份 · 精准计算引擎 · 实时政策</text>
    </view>
  </view>

  <!-- 核心优势 -->
  <view class="advantages">
    <view class="adv-item">
      <text class="adv-num">31</text>
      <text class="adv-label">省/自治区</text>
      <text class="adv-sub">覆盖全国各省</text>
    </view>
    <view class="adv-divider"></view>
    <view class="adv-item">
      <text class="adv-num">140+</text>
      <text class="adv-label">真实案例</text>
      <text class="adv-sub">核定表验证通过</text>
    </view>
    <view class="adv-divider"></view>
    <view class="adv-item">
      <text class="adv-num">实时</text>
      <text class="adv-label">延迟退休</text>
      <text class="adv-sub">最新政策已纳入</text>
    </view>
  </view>

  <!-- 开始按钮 -->
  <button class="btn-start" bindtap="onStart">
    <text class="btn-text">开始测算</text>
    <text class="btn-arrow">›</text>
  </button>

  <!-- 底部说明 -->
  <view class="footer">
    <text class="footer-text">本测算结果仅供参考，实际待遇以社保部门核定为准</text>
  </view>
</view>
