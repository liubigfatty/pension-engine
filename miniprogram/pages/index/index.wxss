/* pages/index/index.wxss - 回退到宽松布局（用户反馈：太紧凑了）*/

.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  padding: var(--space-lg);  /* 回退到宽松padding */
}

/* 主视觉区域 */
.hero {
  width: 100%;
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 120rpx;  /* 回退到宽松的顶部间距 */
  padding-bottom: 60rpx;  /* 回退到宽松的底部间距 */
}

.logo-img {
  width: 400rpx;  /* 回退到大的logo */
  height: 300rpx;  /* 回退到大的logo */
  border-radius: var(--radius-lg);
  box-shadow: 0 16rpx 48rpx rgba(0,0,0,0.3);  /* 回退到大的阴影 */
}

.hero-overlay {
  margin-top: var(--space-lg);  /* 回退到宽松的margin */
  text-align: center;
}

.brand-name {
  display: block;
  font-size: 52rpx;  /* 回退到大的品牌名（原来56rpx，略缩小一点） */
  font-weight: var(--font-weight-bold);
  color: var(--color-text-white);
  letter-spacing: 6rpx;  /* 回退到大的字间距 */
  text-shadow: 0 4rpx 12rpx rgba(0,0,0,0.3);  /* 回退到大的阴影 */
}

.brand-slogan {
  display: block;
  margin-top: var(--space-md);  /* 回退到宽松的margin */
  font-size: var(--font-size-sm);  /* 26rpx */
  color: rgba(255,255,255,0.75);
  letter-spacing: 2rpx;  /* 回退到大的字间距 */
}

.brand-tagline {
  display: block;
  margin-top: var(--space-sm);  /* 回退到宽松的margin */
  font-size: var(--font-size-xs);  /* 22rpx */
  color: rgba(7,193,96,0.9);
  font-weight: var(--font-weight-medium);
  letter-spacing: 1rpx;  /* 回退到大的字间距 */
}

/* 核心优势 - 回退到宽松布局 */
.advantages {
  width: 90%;
  background: rgba(255,255,255,0.08);
  border-radius: var(--radius-xl);
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding: var(--space-xl) var(--space-md);  /* 回退到宽松的padding */
  margin-top: var(--space-xl);  /* 回退到宽松的margin */
  backdrop-filter: blur(10px);
}

.adv-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.adv-num {
  font-size: var(--font-size-xl);  /* 44rpx（回退到大的数字） */
  font-weight: var(--font-weight-bold);
  color: var(--color-primary);
}

.adv-label {
  font-size: var(--font-size-sm);  /* 26rpx（回退到原来的大小） */
  color: rgba(255,255,255,0.85);
  margin-top: var(--space-xs);  /* 回退到宽松的margin */
}

.adv-sub {
  font-size: var(--font-size-xs);  /* 22rpx（回退到原来的大小） */
  color: rgba(255,255,255,0.5);
  margin-top: 4rpx;  /* 回退到宽松的margin */
}

.adv-divider {
  width: 1rpx;
  height: 80rpx;  /* 回退到高的divider */
  background: rgba(255,255,255,0.15);
}

/* 开始按钮 - 回退到宽松布局 */
.btn-start {
  width: 85%;  /* 回退到宽的按钮 */
  margin-top: var(--space-xxl);  /* 回退到宽松的margin */
}

.btn-text { 
  letter-spacing: 6rpx;  /* 回退到大的字间距 */
}

.btn-arrow { 
  font-size: 44rpx;  /* 回退到大的箭头 */
  line-height: 1; 
}

/* 底部说明 - 回退到宽松布局 */
.footer {
  position: fixed;
  bottom: var(--space-md);  /* 回退到宽松的底部间距 */
  left: 0;
  right: 0;
  text-align: center;
  padding: 0 var(--space-xxl);  /* 回退到宽松的左右padding */
}

.footer-text {
  font-size: var(--font-size-xs);  /* 22rpx（回退到原来的大小） */
  color: rgba(255,255,255,0.35);
}

/* 隐私协议弹窗 - 回退到宽松布局 */
.privacy-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

.privacy-popup {
  width: 80%;
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: var(--space-xxl) var(--space-xl);  /* 回退到宽松的padding */
  box-shadow: 0 16rpx 48rpx rgba(0,0,0,0.3);  /* 回退到大的阴影 */
}

.privacy-title {
  font-size: var(--font-size-lg);  /* 38rpx（回退到原来的大小） */
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
  text-align: center;
  margin-bottom: var(--space-xxl);  /* 回退到宽松的margin */
}

.privacy-content {
  font-size: var(--font-size-base);  /* 30rpx（回退到原来的大小） */
  color: var(--color-text-secondary);
  line-height: var(--line-height-normal);
  margin-bottom: var(--space-xxl);  /* 回退到宽松的margin */
  text-align: justify;
}

.privacy-actions {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);  /* 回退到宽松的间距 */
}

.privacy-btn-view {
  background: var(--color-bg-input);
  color: var(--color-primary);
  border: 2rpx solid var(--color-primary);
  border-radius: var(--radius-round);
  font-size: var(--font-size-base);  /* 30rpx（回退到原来的大小） */
  padding: var(--space-md) 0;  /* 回退到宽松的padding */
}

.privacy-btn-disagree {
  background: var(--color-bg-card);
  color: var(--color-text-hint);
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-round);
  font-size: var(--font-size-base);  /* 30rpx（回退到原来的大小） */
  padding: var(--space-md) 0;  /* 回退到宽松的padding */
}

.privacy-btn-agree {
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
  color: var(--color-text-white);
  border: none;
  border-radius: var(--radius-round);
  font-size: var(--font-size-md);  /* 34rpx（回退到原来的大小） */
  font-weight: var(--font-weight-medium);
  padding: var(--space-md) 0;  /* 回退到宽松的padding */
  box-shadow: var(--shadow-primary);
}

.privacy-btn-agree::after {
  border: none;
}
