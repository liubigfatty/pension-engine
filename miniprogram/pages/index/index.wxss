/* pages/index/index.wxss - 使用全局设计系统 v2.0 */

.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  padding: var(--space-lg);
}

/* 主视觉区域 */
.hero {
  width: 100%;
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 120rpx;
  padding-bottom: 60rpx;
}

.logo-img {
  width: 400rpx;
  height: 300rpx;
  border-radius: var(--radius-lg);
  box-shadow: 0 16rpx 48rpx rgba(0,0,0,0.3);
}

.hero-overlay {
  margin-top: var(--space-lg);
  text-align: center;
}

.brand-name {
  display: block;
  font-size: var(--font-size-xxl);  /* 56rpx */
  font-weight: var(--font-weight-bold);
  color: var(--color-text-white);
  letter-spacing: 6rpx;
  text-shadow: 0 4rpx 12rpx rgba(0,0,0,0.3);
}

.brand-slogan {
  display: block;
  margin-top: var(--space-md);
  font-size: var(--font-size-sm);  /* 26rpx */
  color: rgba(255,255,255,0.75);
  letter-spacing: 2rpx;
}

.brand-tagline {
  display: block;
  margin-top: var(--space-sm);
  font-size: var(--font-size-xs);  /* 22rpx */
  color: rgba(7,193,96,0.9);
  font-weight: var(--font-weight-medium);
  letter-spacing: 1rpx;
}

/* 核心优势 */
.advantages {
  width: 90%;
  background: rgba(255,255,255,0.08);
  border-radius: var(--radius-xl);
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding: var(--space-xl) var(--space-md);
  margin-top: var(--space-lg);
  backdrop-filter: blur(10px);
}

.adv-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.adv-num {
  font-size: var(--font-size-xl);  /* 44rpx */
  font-weight: var(--font-weight-bold);
  color: var(--color-primary);
}

.adv-label {
  font-size: var(--font-size-sm);  /* 26rpx */
  color: rgba(255,255,255,0.85);
  margin-top: var(--space-xs);
}

.adv-sub {
  font-size: var(--font-size-xs);  /* 22rpx */
  color: rgba(255,255,255,0.5);
  margin-top: 4rpx;
}

.adv-divider {
  width: 1rpx;
  height: 80rpx;
  background: rgba(255,255,255,0.15);
}

/* 开始按钮（基于全局.btn-primary，增加特有的光泽动画） */
.btn-start {
  width: 85%;
  margin-top: var(--space-xxl);
}

/* 按钮光泽动画 */
.btn-start::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
  animation: btnShine 3s infinite;
}

@keyframes btnShine {
  0% { left: -100%; }
  50% { left: 100%; }
  100% { left: 100%; }
}

.btn-text { 
  letter-spacing: 6rpx; 
}

.btn-arrow { 
  font-size: 44rpx; 
  line-height: 1; 
}

/* 底部说明 */
.footer {
  position: fixed;
  bottom: var(--space-md);
  left: 0;
  right: 0;
  text-align: center;
  padding: 0 var(--space-xxl);
}

.footer-text {
  font-size: var(--font-size-xs);  /* 22rpx */
  color: rgba(255,255,255,0.35);
}

/* 隐私协议弹窗 */
.privacy-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

.privacy-popup {
  width: 80%;
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: var(--space-xxl) var(--space-xl);
  box-shadow: 0 16rpx 48rpx rgba(0,0,0,0.3);
}

.privacy-title {
  font-size: var(--font-size-lg);  /* 38rpx */
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
  text-align: center;
  margin-bottom: var(--space-xl);
}

.privacy-content {
  font-size: var(--font-size-base);  /* 30rpx */
  color: var(--color-text-secondary);
  line-height: var(--line-height-normal);
  margin-bottom: var(--space-xxl);
  text-align: justify;
}

.privacy-actions {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
}

.privacy-btn-view {
  background: var(--color-bg-input);
  color: var(--color-primary);
  border: 2rpx solid var(--color-primary);
  border-radius: var(--radius-round);
  font-size: var(--font-size-base);  /* 30rpx */
  padding: var(--space-md) 0;
}

.privacy-btn-disagree {
  background: var(--color-bg-card);
  color: var(--color-text-hint);
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-round);
  font-size: var(--font-size-base);  /* 30rpx */
  padding: var(--space-md) 0;
}

.privacy-btn-agree {
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
  color: var(--color-text-white);
  border: none;
  border-radius: var(--radius-round);
  font-size: var(--font-size-md);  /* 34rpx */
  font-weight: var(--font-weight-medium);
  padding: var(--space-md) 0;
  box-shadow: var(--shadow-primary);
}

.privacy-btn-agree::after {
  border: none;
}
