/* pages/index/index.wxss - 首页样式 */
.container {
  min-height: 100vh;
  background: #f8f9fa;
}

.hero {
  background: linear-gradient(135deg, #1e3a5f 0%, #2563eb 100%);
  padding: 60rpx 40rpx 80rpx;
  color: #ffffff;
}

.hero-title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  line-height: 1.3;
}

.hero-subtitle {
  display: block;
  font-size: 26rpx;
  margin-top: 16rpx;
  opacity: 0.85;
}

.menu {
  margin-top: -40rpx;
  padding: 0 24rpx;
}

.menu-card {
  display: flex;
  align-items: center;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.menu-icon {
  font-size: 48rpx;
  margin-right: 24rpx;
  width: 60rpx;
  text-align: center;
}

.menu-text {
  flex: 1;
}

.menu-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 6rpx;
}

.menu-desc {
  display: block;
  font-size: 24rpx;
  color: #6b7280;
}

.menu-arrow {
  font-size: 40rpx;
  color: #d1d5db;
  margin-left: 12rpx;
}

.footer {
  text-align: center;
  padding: 40rpx 0 60rpx;
}

.footer-text {
  font-size: 22rpx;
  color: #9ca3af;
  display: block;
  margin-bottom: 16rpx;
}

.help-link {
  display: inline-block;
  font-size: 26rpx;
  color: #2563eb;
  padding: 8rpx 24rpx;
  border: 2rpx solid #2563eb;
  border-radius: 24rpx;
}
