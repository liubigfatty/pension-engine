/* pages/index/index.wxss */

.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
}

/* 主视觉区域 */
.hero {
  width: 100%;
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 120rpx;
  padding-bottom: 60rpx;
}

.logo-img {
  width: 400rpx;
  height: 300rpx;
  border-radius: 24rpx;
  box-shadow: 0 16rpx 48rpx rgba(0,0,0,0.3);
}

.hero-overlay {
  margin-top: 40rpx;
  text-align: center;
}

.brand-name {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: #fff;
  letter-spacing: 4rpx;
}

.brand-desc {
  display: block;
  margin-top: 16rpx;
  font-size: 26rpx;
  color: rgba(255,255,255,0.6);
}

/* 核心优势 */
.advantages {
  width: 90%;
  background: rgba(255,255,255,0.08);
  border-radius: 24rpx;
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding: 40rpx 20rpx;
  margin-top: 40rpx;
  backdrop-filter: blur(10px);
}

.adv-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.adv-num {
  font-size: 44rpx;
  font-weight: bold;
  color: #07c160;
}

.adv-label {
  font-size: 26rpx;
  color: rgba(255,255,255,0.85);
  margin-top: 8rpx;
}

.adv-sub {
  font-size: 22rpx;
  color: rgba(255,255,255,0.5);
  margin-top: 4rpx;
}

.adv-divider {
  width: 1rpx;
  height: 80rpx;
  background: rgba(255,255,255,0.15);
}

/* 开始按钮 */
.btn-start {
  width: 85%;
  margin-top: 60rpx;
  background: linear-gradient(135deg, #07c160 0%, #06ae56 100%);
  color: #fff;
  border: none;
  border-radius: 50rpx;
  padding: 28rpx 0;
  font-size: 36rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  box-shadow: 0 8rpx 32rpx rgba(7,193,96,0.35);
}

.btn-text { letter-spacing: 6rpx; }
.btn-arrow { font-size: 44rpx; line-height: 1; }

.btn-start::after { border: none; }

/* 底部说明 */
.footer {
  position: fixed;
  bottom: 40rpx;
  left: 0;
  right: 0;
  text-align: center;
  padding: 0 50rpx;
}

.footer-text {
  font-size: 22rpx;
  color: rgba(255,255,255,0.35);
}

/* 隐私协议弹窗 */
.privacy-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

.privacy-popup {
  width: 80%;
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  box-shadow: 0 16rpx 48rpx rgba(0,0,0,0.3);
}

.privacy-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin-bottom: 32rpx;
}

.privacy-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 40rpx;
  text-align: justify;
}

.privacy-actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.privacy-btn-view {
  background: #f5f5f5;
  color: #07c160;
  border: 2rpx solid #07c160;
  border-radius: 12rpx;
  font-size: 28rpx;
  padding: 20rpx 0;
}

.privacy-btn-disagree {
  background: #fff;
  color: #999;
  border: 2rpx solid #ddd;
  border-radius: 12rpx;
  font-size: 28rpx;
  padding: 20rpx 0;
}

.privacy-btn-agree {
  background: linear-gradient(135deg, #07c160 0%, #06ae56 100%);
  color: #fff;
  border: none;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: 600;
  padding: 24rpx 0;
  box-shadow: 0 8rpx 24rpx rgba(7,193,96,0.35);
}

.privacy-btn-agree::after {
  border: none;
}
